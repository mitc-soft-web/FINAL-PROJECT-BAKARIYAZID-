@model QRCodeAttendance.Models.DTOs.StudentDashboardDto
@{
    ViewData["Title"] = "Scan Attendance";
}

<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    
    <style>
        :root {
            --student-accent: #0ea5e9;
            --student-bg: #f0f9ff;
        }

        body {
            background-color: var(--student-bg);
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        .scanner-card {
            background: white;
            border-radius: 30px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            overflow: hidden;
            border: none;
        }

        /* This is where the camera video will show */
        #reader {
            width: 100%;
            background: #000;
            border-radius: 20px;
        }

        /* Style the library's internal buttons to match your theme */
        #reader button {
            background-color: var(--student-accent) !important;
            color: white !important;
            border: none !important;
            padding: 10px 20px !important;
            border-radius: 50px !important;
            font-weight: bold !important;
            margin: 10px !important;
        }
    </style>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="with-portal-chrome">
    @await Html.PartialAsync("_PortalHeader")

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="scanner-card p-4 text-center">
                <div class="mb-4">
                    <i class="fa fa-qrcode text-primary fa-3x mb-3"></i>
                    <h2 class="fw-bold">Scan QR Code</h2>
                    <p class="text-muted">Align the QR code within the frame to mark your attendance</p>
                </div>

                @* THE CAMERA VIEWPORT *@
                <div id="reader" class="mb-4"></div>

                <div id="result"></div>

                @if (ViewBag.ErrorMessage != null)
                {
                    <div class="alert alert-danger rounded-4 fw-semibold">@ViewBag.ErrorMessage</div>
                }

                <a asp-action="StudentDashboard" asp-controller="Student" class="btn btn-outline-secondary rounded-pill px-4">
                    <i class="fa fa-arrow-left me-2"></i>Back to Dashboard
                </a>
            </div>
        </div>
    </div>
</div>

@* Hidden form to send data back to your Controller *@
<form id="attendanceForm" action="/attendance/scan" method="post">
    <input type="hidden" id="sessionId" name="sessionId" value="@ViewBag.SessionId" />
    <input type="hidden" id="qrCodeData" name="qrCode" />
</form>

@* Load the QR Library *@
<script src="https://unpkg.com/html5-qrcode"></script>

<script>
    const offlineQueueKey = "attendanceOfflineScanQueue";
    const sessionId = document.getElementById('sessionId').value;
    const resultEl = document.getElementById('result');

    function getQueuedScans() {
        try {
            return JSON.parse(localStorage.getItem(offlineQueueKey) || "[]");
        } catch {
            return [];
        }
    }

    function saveQueuedScans(scans) {
        localStorage.setItem(offlineQueueKey, JSON.stringify(scans));
    }

    function renderScanMessage(message, type = "info") {
        resultEl.innerHTML = `<div class="alert alert-${type} rounded-pill">${message}</div>`;
    }

    function queueScan(qrCode) {
        const scans = getQueuedScans();
        const scan = {
            sessionId,
            qrCode,
            scannedAt: new Date().toISOString(),
            clientScanId: crypto.randomUUID ? crypto.randomUUID() : `${Date.now()}-${Math.random()}`
        };

        scans.push(scan);
        scans.sort((a, b) => new Date(a.scannedAt) - new Date(b.scannedAt));
        saveQueuedScans(scans);
        return scan;
    }

    async function syncQueuedScans(redirectWhenDone = false) {
        if (!navigator.onLine) {
            renderScanMessage("Scan saved offline. It will sync when your connection returns.", "warning");
            return;
        }

        const scans = getQueuedScans().sort((a, b) => new Date(a.scannedAt) - new Date(b.scannedAt));
        const remaining = [];
        let syncedCount = 0;
        let lastMessage = "";
        let rejectedCount = 0;

        for (const scan of scans) {
            try {
                const response = await fetch("/attendance/sync-offline", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(scan)
                });

                if (!response.ok) {
                    remaining.push(scan);
                    continue;
                }

                const result = await response.json();
                lastMessage = result.message || "";

                if (result.synced) {
                    syncedCount++;
                } else {
                    rejectedCount++;
                }
            } catch {
                remaining.push(scan);
            }
        }

        saveQueuedScans(remaining);

        if (remaining.length > 0) {
            renderScanMessage(lastMessage || `${remaining.length} scan(s) are still waiting to sync.`, "warning");
            return;
        }

        if (syncedCount > 0) {
            renderScanMessage(lastMessage || "Scan synced successfully.", "success");
            if (redirectWhenDone) {
                window.location.href = "@Url.Action("StudentDashboard", "Student")";
            }
        } else if (rejectedCount > 0) {
            renderScanMessage(lastMessage || "Scan was processed but not accepted.", "warning");
        }
    }

    function onScanSuccess(decodedText, decodedResult) {
        html5QrcodeScanner.clear();
        queueScan(decodedText);
        renderScanMessage("Code detected. Syncing...", "success");
        syncQueuedScans(true);
    }

    function onScanFailure(error) {
        // We ignore failures as they happen constantly until a code is found
    }

    let html5QrcodeScanner = new Html5QrcodeScanner(
        "reader", 
        { 
            fps: 10, 
            qrbox: { width: 250, height: 250 },
            aspectRatio: 1.0 
        }, 
        false);

    html5QrcodeScanner.render(onScanSuccess, onScanFailure);
    window.addEventListener("online", () => syncQueuedScans(false));
    syncQueuedScans(false);
</script>

    @await Html.PartialAsync("_PortalFooter")
</body>
</html>
