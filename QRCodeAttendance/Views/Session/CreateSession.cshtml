@using QRCodeAttendance.Models.Enums
@model QRCodeAttendance.Models.DTOs.Session.CreateSessionRequestModel

@{
    ViewData["Title"] = "Create New Session";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    :root {
        --glass-bg: rgba(15, 23, 42, 0.7);
        --glass-border: rgba(255, 255, 255, 0.1);
        --accent-color: #4ade80;
        --input-bg: rgba(255, 255, 255, 0.03);
    }

    body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background: linear-gradient(rgba(15, 23, 42, 0.8), rgba(15, 23, 42, 0.9)), 
                    url('https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&fit=crop&q=80&w=2070');
        background-size: cover;
        background-attachment: fixed;
        background-position: center;
        min-height: 100vh;
        color: white;
    }

    .form-glass-card {
        background: var(--glass-bg);
        backdrop-filter: blur(20px) saturate(180%);
        border: 1px solid var(--glass-border);
        border-radius: 40px;
        box-shadow: 0 40px 100px rgba(0, 0, 0, 0.5);
        max-width: 700px; /* Slightly wider to accommodate the extra field */
        margin: auto;
        position: relative;
        overflow: hidden;
    }

    .form-glass-card::before {
        content: "";
        position: absolute;
        top: 0; left: 0; width: 100%; height: 6px;
        background: linear-gradient(90deg, transparent, var(--accent-color), transparent);
    }

    .form-control-custom {
        background: var(--input-bg) !important;
        border: 1px solid var(--glass-border) !important;
        color: white !important;
        border-radius: 15px !important;
        padding: 14px 18px !important;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    select.form-control-custom option {
        background-color: #1e293b;
        color: white;
    }

    .form-control-custom:focus {
        border-color: var(--accent-color) !important;
        box-shadow: 0 0 0 4px rgba(74, 222, 128, 0.1) !important;
        background: rgba(255, 255, 255, 0.08) !important;
        transform: translateY(-1px);
    }

    .label-accent {
        color: #94a3b8;
        font-weight: 600;
        font-size: 0.75rem;
        margin-bottom: 8px;
        margin-left: 5px;
        text-transform: uppercase;
        letter-spacing: 1.5px;
    }

    .btn-create {
        background: var(--accent-color);
        color: #0f172a;
        font-weight: 800;
        border: none;
        border-radius: 18px;
        padding: 18px;
        width: 100%;
        transition: all 0.4s;
        box-shadow: 0 10px 30px rgba(74, 222, 128, 0.2);
    }

    .btn-create:hover {
        transform: translateY(-3px) scale(1.01);
        box-shadow: 0 20px 40px rgba(74, 222, 128, 0.3);
        background: #22c55e;
    }

    .alert-custom {
        background: rgba(248, 113, 113, 0.1);
        border: 1px solid #f87171;
        color: #f87171;
        border-radius: 15px;
        font-weight: 500;
    }

    .time-slot-badge {
        background: rgba(99, 102, 241, 0.1);
        color: #818cf8;
        padding: 4px 12px;
        border-radius: 100px;
        font-size: 0.7rem;
        font-weight: 700;
    }
</style>

<div class="container py-5">
    <div class="form-glass-card p-4 p-md-5 animate__animated animate__fadeIn">
        <div class="text-center mb-5">
            <h2 class="fw-800 display-6">New Session</h2>
            <p class="text-white-50">Set up your attendance tracking parameters</p>
        </div>

        <div id="validation-error" class="alert alert-custom text-center mb-4 d-none"></div>

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-custom text-center mb-4">
                <i class="fas fa-exclamation-circle me-2"></i> @ViewBag.ErrorMessage
            </div>
        }

        <form asp-controller="Session" asp-action="CreateSession" method="post" id="sessionForm">
            <div class="row g-4">
                
                @* Course Name *@
                <div class="col-md-12">
                    <label class="label-accent">Course Name</label>
                    <input asp-for="CourseName" class="form-control form-control-custom" placeholder="Advanced Software Engineering" required />
                </div>

                @* Course Code *@
                <div class="col-md-4">
                    <label class="label-accent">Course Code</label>
                    <input asp-for="CourseCode" class="form-control form-control-custom" placeholder="SEW-204" required />
                </div>

                @* Department (Newly Added) *@
                <div class="col-md-4">
                    <label class="label-accent">Department</label>
                    <select asp-for="Department" class="form-control form-control-custom" 
                            asp-items="@Html.GetEnumSelectList(typeof(Departments))" required>
                        <option value="">-- Department --</option>
                    </select>
                </div>

                @* Target Level *@
                <div class="col-md-4">
                    <label class="label-accent">Student Level</label>
                    <select asp-for="Level" class="form-control form-control-custom" 
                            asp-items="@Html.GetEnumSelectList(typeof(StudentLevel))" required>
                        <option value="">-- Level --</option>
                    </select>
                </div>

                @* Start Time *@
                <div class="col-md-6">
                    <label class="label-accent">Starts At</label>
                    <input asp-for="SessionStartTime" type="datetime-local" id="startTime" class="form-control form-control-custom" required />
                </div>

                @* End Time *@
                <div class="col-md-6">
                    <label class="label-accent">Ends At <span class="time-slot-badge">Min 1 Hr</span></label>
                    <input asp-for="SessionEndTime" type="datetime-local" id="endTime" class="form-control form-control-custom" required />
                </div>

                @* QR Expiry *@
                <div class="col-md-12">
                    <label class="label-accent">QR Rotation Expiry</label>
                    <input asp-for="QRCodeExpiry" type="datetime-local" id="qrExpiry" class="form-control form-control-custom" required />
                    <small class="text-white-50 mt-2 d-block ms-1">
                        <i class="fas fa-info-circle me-1"></i> QR will expire at least 10 minutes before class ends.
                    </small>
                </div>

                <div class="col-12 mt-5">
                    <button type="submit" class="btn btn-create">
                        ACTIVATE SESSION <i class="fas fa-bolt ms-2"></i>
                    </button>
                    <a asp-action="InstructorDashboard" asp-controller="Instructor" class="btn btn-link w-100 mt-3 text-white-50 text-decoration-none small">
                        Back to Dashboard
                    </a>
                     <a asp-action="Details" asp-controller="Session" class="text-white-50 text-decoration-none small">Back to Details</a>
                </div>

            </div>
        </form>
    </div>
</div>

<script>
    // [Same JavaScript as before remains here for validation]
    const form = document.getElementById('sessionForm');
    const startInput = document.getElementById('startTime');
    const endInput = document.getElementById('endTime');
    const qrInput = document.getElementById('qrExpiry');
    const errorDiv = document.getElementById('validation-error');

    function showError(msg) {
        errorDiv.innerText = msg;
        errorDiv.classList.remove('d-none');
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    form.addEventListener('submit', function (e) {
        const now = new Date();
        now.setMinutes(now.getMinutes() - 1); 

        const start = new Date(startInput.value);
        const end = new Date(endInput.value);
        const qr = new Date(qrInput.value);
        
        errorDiv.classList.add('d-none');

        if (start < now) {
            e.preventDefault();
            showError("The session cannot start in the past.");
            return;
        }

        const diffInMs = end - start;
        const diffInMinutes = Math.floor(diffInMs / (1000 * 60));

        if (diffInMinutes < 60) {
            e.preventDefault();
            showError(`Duration is only ${diffInMinutes} minutes. It must be at least 60 minutes.`);
            return;
        }

        const hardLimit = new Date(end.getTime() - (10 * 60 * 1000));
        if (qr > hardLimit) {
            e.preventDefault();
            showError("QR Expiry must be at least 10 minutes before class ends.");
            return;
        }
    });

    endInput.addEventListener('change', function() {
        if(endInput.value) {
            const end = new Date(endInput.value);
            const suggestedQr = new Date(end.getTime() - (10 * 60 * 1000));
            
            const year = suggestedQr.getFullYear();
            const month = String(suggestedQr.getMonth() + 1).padStart(2, '0');
            const day = String(suggestedQr.getDate()).padStart(2, '0');
            const hours = String(suggestedQr.getHours()).padStart(2, '0');
            const mins = String(suggestedQr.getMinutes()).padStart(2, '0');
            
            qrInput.value = `${year}-${month}-${day}T${hours}:${mins}`;
        }
    });
</script>