@using QRCodeAttendance.Models.DTOs.Session
@using QRCodeAttendance.Models.Enums
@model UpdateSessionRequestModel
@{
    Layout = null; // Or your main layout
}

<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.Name">

<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
            :root {
                --glass-bg: rgba(255, 255, 255, 0.05);
                --glass-border: rgba(255, 255, 255, 0.12);
                --accent-green: #10b981;
            }

            body {
                background: radial-gradient(circle at top left, #0f172a, #1e293b);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                font-family: 'Inter', sans-serif;
                color: #f8fafc;
            }

            .edit-session-shell {
                min-height: calc(100dvh - var(--portal-header-height, 76px) - var(--portal-footer-height, 56px));
                width: 100%;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: clamp(1rem, 3vw, 2rem);
            }

            .edit-container {
                width: 100%;
                max-width: 850px;
                margin: 0 auto;
                background: var(--glass-bg);
                backdrop-filter: blur(25px) saturate(180%);
                border: 1px solid var(--glass-border);
                border-radius: 30px;
                padding: 3rem;
                box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            }

            .form-header {
                border-bottom: 1px solid var(--glass-border);
                padding-bottom: 1.5rem;
                margin-bottom: 2rem;
            }

            .input-box {
                background: rgba(0, 0, 0, 0.2);
                border: 1px solid var(--glass-border);
                border-radius: 12px;
                padding: 12px 15px;
                margin-bottom: 1.5rem;
                transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            }

            .input-box:focus-within {
                border-color: var(--accent-green);
                background: rgba(16, 185, 129, 0.05);
                transform: translateY(-2px);
            }

            .input-box label {
                display: block;
                font-size: 0.7rem;
                text-transform: uppercase;
                letter-spacing: 1px;
                color: var(--accent-green);
                margin-bottom: 5px;
                font-weight: 700;
            }

            .input-box input,
            .input-box select {
                background: transparent;
                border: none;
                color: white;
                width: 100%;
                outline: none;
                font-size: 1rem;
            }

            .glass-input option {
                background-color: #1e293b !important;
                color: white !important;
            }

            select.glass-input {
                appearance: none;
                background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%2310b981' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e");
                background-repeat: no-repeat;
                background-position: right 1rem center;
                background-size: 14px;
                padding-right: 2.5rem;
            }

            input[type="datetime-local"]::-webkit-calendar-picker-indicator {
                filter: invert(1);
                cursor: pointer;
            }

            .btn-update {
                background: linear-gradient(135deg, #10b981, #059669);
                border: none;
                border-radius: 12px;
                padding: 14px;
                font-weight: 700;
                color: white;
                width: 100%;
                transition: 0.4s;
                text-transform: uppercase;
                letter-spacing: 1px;
            }

            .btn-update:hover {
                box-shadow: 0 0 20px rgba(16, 185, 129, 0.4);
                transform: scale(1.02);
            }

            .btn-discard {
                background: rgba(255, 255, 255, 0.05);
                border: 1px solid var(--glass-border);
                border-radius: 12px;
                padding: 14px;
                color: #94a3b8;
                text-decoration: none;
                text-align: center;
                display: block;
                transition: 0.3s;
            }

            .btn-discard:hover {
                background: rgba(255, 255, 255, 0.1);
                color: white;
            }

            @@media (max-width: 768px) {
                .edit-session-shell {
                    align-items: flex-start;
                }
            }
    </style>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="with-portal-chrome">
    @await Html.PartialAsync("_PortalHeader")

    <main class="edit-session-shell">
    <div class="edit-container">
        <div class="form-header">
            <h2 class="mb-1">Edit Session</h2>
            <p class=" text-light  small mb-0">Modify course details and time synchronization for this session.</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger border-0 text-white py-2"
                 style="background: rgba(239, 68, 68, 0.2); border-radius: 10px;">
                <i class="fas fa-circle-exclamation me-2"></i> @ViewBag.Error
            </div>
        }

        <form asp-action="EditSession" asp-route-sessionId="@ViewBag.SessionId" method="post">
            <div class="row">
                <div class="col-md-8">
                    <div class="input-box">
                        <label>Course Name</label>
                        <input asp-for="CourseName" placeholder="e.g. Advanced C# Development" />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="input-box">
                        <label>Course Code</label>
                        <input asp-for="CourseCode" placeholder="CSC 401" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="input-box">
                        <label class="glass-label">Student Level</label>
                        <select asp-for="Level" asp-items="Html.GetEnumSelectList<StudentLevel>()"
                                class="form-control glass-input">
                        </select>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="input-box">
                        <label class="glass-label">Department</label>
                        <select asp-for="Department" asp-items="Html.GetEnumSelectList<Departments>()"
                                class="form-control glass-input">
                        </select>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="input-box">
                        <label>Start Time</label>
                        <input asp-for="SessionStartTime" type="datetime-local" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="input-box">
                        <label>End Time</label>
                        <input asp-for="SessionEndTime" type="datetime-local" />
                    </div>
                </div>
            </div>

            <div class="row g-3 mt-4">
                <div class="col-md-8">
                    <button type="submit" class="btn-update">Commit Changes</button>
                </div>
                <div class="col-md-4">
                    <a asp-action="Details" asp-route-id="@ViewBag.SessionId" class="btn-discard">Discard</a>
                </div>
            </div>
        </form>
    </div>
    </main>

    @await Html.PartialAsync("_PortalFooter")
</body>

</html>
