@model QRCodeAttendance.Models.DTOs.Session.SessionDto

@{
    ViewData["Title"] = "Delete Session";
    Layout = null;
}

<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --page-bg: #0f172a;
            --panel: rgba(255, 255, 255, 0.08);
            --panel-strong: rgba(255, 255, 255, 0.12);
            --border: rgba(255, 255, 255, 0.16);
            --text: #f8fafc;
            --muted: #cbd5e1;
            --danger: #ef4444;
            --danger-dark: #b91c1c;
        }

        body {
            min-height: 100vh;
            margin: 0;
            display: grid;
            place-items: center;
            padding: 24px;
            color: var(--text);
            font-family: 'Plus Jakarta Sans', sans-serif;
            background:
                radial-gradient(circle at 18% 18%, rgba(239, 68, 68, 0.22), transparent 28%),
                radial-gradient(circle at 82% 12%, rgba(56, 189, 248, 0.18), transparent 26%),
                linear-gradient(135deg, #111827 0%, #0f172a 48%, #020617 100%);
        }

        .delete-shell {
            width: min(100%, 720px);
        }

        .delete-panel {
            overflow: hidden;
            border: 1px solid var(--border);
            border-radius: 28px;
            background: linear-gradient(145deg, var(--panel-strong), var(--panel));
            box-shadow: 0 28px 80px rgba(2, 6, 23, 0.48);
            backdrop-filter: blur(22px) saturate(150%);
        }

        .panel-header {
            padding: 34px 34px 24px;
            border-bottom: 1px solid var(--border);
        }

        .warning-icon {
            width: 58px;
            height: 58px;
            display: grid;
            place-items: center;
            margin-bottom: 20px;
            border-radius: 18px;
            color: #fee2e2;
            background: rgba(239, 68, 68, 0.18);
            border: 1px solid rgba(239, 68, 68, 0.32);
            font-size: 1.5rem;
        }

        h1 {
            margin: 0;
            font-size: clamp(1.8rem, 4vw, 2.8rem);
            font-weight: 800;
            letter-spacing: 0;
        }

        .lead-copy {
            margin: 12px 0 0;
            color: var(--muted);
            font-size: 1rem;
            line-height: 1.7;
        }

        .session-summary {
            padding: 24px 34px;
        }

        .summary-card {
            border: 1px solid var(--border);
            border-radius: 18px;
            background: rgba(15, 23, 42, 0.42);
            padding: 22px;
        }

        .course-title {
            margin: 0 0 10px;
            font-size: 1.25rem;
            font-weight: 800;
        }

        .course-code {
            color: #94a3b8;
            font-weight: 700;
        }

        .meta-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
            margin-top: 18px;
        }

        .meta-item {
            min-height: 74px;
            padding: 14px;
            border-radius: 14px;
            background: rgba(255, 255, 255, 0.06);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .meta-label {
            margin: 0 0 6px;
            color: #94a3b8;
            font-size: 0.72rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .meta-value {
            margin: 0;
            color: var(--text);
            font-weight: 700;
        }

        .actions {
            display: flex;
            gap: 14px;
            justify-content: flex-end;
            padding: 0 34px 34px;
            flex-wrap: wrap;
        }

        .btn-cancel,
        .btn-delete {
            min-height: 48px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            border-radius: 14px;
            padding: 0 20px;
            font-weight: 800;
            text-decoration: none;
            transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
        }

        .btn-cancel {
            color: var(--text);
            border: 1px solid var(--border);
            background: rgba(255, 255, 255, 0.08);
        }

        .btn-delete {
            color: white;
            border: 0;
            background: linear-gradient(135deg, var(--danger), var(--danger-dark));
            box-shadow: 0 16px 36px rgba(239, 68, 68, 0.24);
        }

        .btn-cancel:hover,
        .btn-delete:hover {
            transform: translateY(-2px);
            color: white;
        }

        .btn-delete:hover {
            box-shadow: 0 20px 42px rgba(239, 68, 68, 0.34);
        }

        @@media (max-width: 576px) {
            .panel-header,
            .session-summary,
            .actions {
                padding-left: 22px;
                padding-right: 22px;
            }

            .meta-grid {
                grid-template-columns: 1fr;
            }

            .actions {
                flex-direction: column-reverse;
            }

            .btn-cancel,
            .btn-delete {
                width: 100%;
            }
        }
    </style>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="with-portal-chrome">
    @await Html.PartialAsync("_PortalHeader")
    <main class="delete-shell">
        <section class="delete-panel">
            <div class="panel-header">
                <div class="warning-icon">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>
                <h1>Delete Session Class?</h1>
                <p class="lead-copy">
                    Are you sure you want to delete this session class? This action cannot be undone.
                </p>
            </div>

            <div class="session-summary">
                <div class="summary-card">
                    <h2 class="course-title">@Model.CourseName</h2>
                    <div class="course-code">#@Model.CourseCode</div>

                    <div class="meta-grid">
                        <div class="meta-item">
                            <p class="meta-label">Department</p>
                            <p class="meta-value">@Model.Department</p>
                        </div>
                        <div class="meta-item">
                            <p class="meta-label">Level</p>
                            <p class="meta-value">@Model.Level.GetDescription()</p>
                        </div>
                        <div class="meta-item">
                            <p class="meta-label">Start Time</p>
                            <p class="meta-value">@Model.SessionStartTime.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt")</p>
                        </div>
                        <div class="meta-item">
                            <p class="meta-label">End Time</p>
                            <p class="meta-value">@Model.SessionEndTime.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt")</p>
                        </div>
                    </div>
                </div>
            </div>

            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="actions">
                @Html.AntiForgeryToken()
                <a asp-action="Details" class="btn-cancel">
                    <i class="fa-solid fa-arrow-left"></i>
                    Keep Session
                </a>
                <button type="submit" class="btn-delete">
                    <i class="fa-solid fa-trash-can"></i>
                    Delete Session
                </button>
            </form>
        </section>
    </main>
    @await Html.PartialAsync("_PortalFooter")
</body>
</html>
