@{
    ViewData["Title"] = "Welcome - QRCodeAttendance";
    Layout = null;
}

<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary-glow: #10b981;
            --surface-glass: rgba(15, 23, 42, 0.45);
            --border-glass: rgba(255, 255, 255, 0.12);
            --text-main: #f8fafc;
            --text-dim: #94a3b8;
        }

        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            min-height: 100%;
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #090d16;
            overflow-x: hidden;
        }

        /* Ambient Background with the Target University/Library Asset */
        .page-wrapper {
            position: relative;
            width: 100%;
            min-height: calc(100vh - var(--portal-header-height) - var(--portal-footer-height));
            display: flex;
            align-items: center;
            justify-content: center;
            /* Dark linear overlay mixed with high-fidelity corporate university background */
            background: linear-gradient(135deg, rgba(15, 23, 42, 0.75) 0%, rgba(9, 13, 22, 0.9) 100%),
                        url('https://images.unsplash.com/photo-1521587760476-6c12a4b040da?q=80&w=2000&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
            padding: 1.5rem;
        }

        /* Smooth floating animation background rings to interact with backdrop blur refraction */
        .ambient-glow-1 {
            position: absolute;
            top: 15%;
            left: 20%;
            width: 450px;
            height: 450px;
            background: radial-gradient(circle, rgba(16, 185, 129, 0.1) 0%, transparent 70%);
            border-radius: 50%;
            animation: floatGlow 14s infinite alternate ease-in-out;
            pointer-events: none;
        }

        .ambient-glow-2 {
            position: absolute;
            bottom: 10%;
            right: 15%;
            width: 550px;
            height: 550px;
            background: radial-gradient(circle, rgba(6, 182, 212, 0.07) 0%, transparent 70%);
            border-radius: 50%;
            animation: floatGlow 20s infinite alternate-reverse ease-in-out;
            pointer-events: none;
        }

        @@keyframes floatGlow {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(50px, -50px) scale(1.1); }
        }

        /* Glassmorphic Portal Frame */
        .portal-card {
            width: 100%;
            max-width: 680px;
            background: var(--surface-glass);
            backdrop-filter: blur(30px) saturate(210%);
            -webkit-backdrop-filter: blur(30px) saturate(210%);
            border: 1px solid var(--border-glass);
            border-radius: 32px;
            padding: 4.5rem 3.5rem;
            box-shadow: 0 50px 120px rgba(0, 0, 0, 0.55),
                        inset 0 1px 0 rgba(255, 255, 255, 0.15);
            text-align: center;
            z-index: 10;
            animation: cardEntrance 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }

        @@keyframes cardEntrance {
            from { opacity: 0; transform: translateY(30px) scale(0.97); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }

        /* Headings & Brand Logo Typography */
        .brand-header {
            margin-bottom: 3.5rem;
        }

        .logo-box {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 16px;
            color: var(--text-main);
        }

        .logo-box i.fa-qrcode {
            font-size: 2.5rem;
            color: var(--primary-glow);
            text-shadow: 0 0 25px rgba(16, 185, 129, 0.45);
        }

        .brand-title {
            font-size: 2rem;
            font-weight: 800;
            letter-spacing: -1.2px;
            margin: 0;
            background: linear-gradient(to right, #ffffff 70%, #cbd5e1);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .brand-version {
            font-size: 1.2rem;
            font-weight: 500;
            color: var(--text-dim);
            letter-spacing: -0.5px;
            margin-left: 5px;
        }

        /* Interactive Navigation Stack */
        .action-stack {
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
            max-width: 460px;
            margin: 0 auto;
        }

        /* Sleek Button Layout */
        .btn-portal {
            width: 100%;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.09);
            border-radius: 100px; /* Pillow-oval architecture matching image precisely */
            padding: 16px 28px;
            color: var(--text-main);
            font-weight: 700;
            font-size: 0.95rem;
            letter-spacing: 0.6px;
            text-transform: uppercase;
            text-decoration: none;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 14px;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        /* Login Active Variation */
        .btn-portal.btn-login {
            background: rgba(255, 255, 255, 0.08);
            border-color: rgba(255, 255, 255, 0.18);
            box-shadow: inset 0 1px 1px rgba(255,255,255,0.1);
        }

        /* High contrast inverse glass transition on hover */
        .btn-portal:hover {
            color: #090d16 !important;
            background: #ffffff;
            border-color: #ffffff;
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(255, 255, 255, 0.12),
                        0 0 0 4px rgba(255, 255, 255, 0.05);
        }

        .btn-portal i {
            font-size: 1.1rem;
            opacity: 0.85;
            transition: transform 0.4s ease;
        }

        .btn-portal:hover i {
            opacity: 1;
            transform: scale(1.1);
        }

        /* Developer Custom Attribution Footer */
        .portal-footer {
            margin-top: 4rem;
            font-size: 0.78rem;
            color: var(--text-dim);
            line-height: 1.6;
            opacity: 0.8;
        }

        .heart-pulse {
            color: #f43f5e;
            display: inline-block;
        }

        /* Responsive Breakpoints */
        @@media (max-width: 768px) {
            .portal-card {
                padding: 3.5rem 2rem;
            }
            .brand-title { font-size: 1.2rem; }
            .brand-version { font-size: 10px; }
        }
    </style>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="with-portal-chrome">
    @await Html.PartialAsync("_PortalHeader")

    <div class="page-wrapper">
        <div class="ambient-glow-1"></div>
        <div class="ambient-glow-2"></div>

        <div class="portal-card">

            <div class="brand-header">
                <div class="logo-box">
                    <i class="fas fa-qrcode"></i>
                    <h1 class="brand-title">QRCodeAttendance<span class="brand-version">v2.0</span></h1>
                </div>
            </div>

            <div class="action-stack">
                <a asp-controller="User" asp-action="Login" class="btn-portal btn-login">
                    <i class="fas fa-user-circle"></i> Login
                </a>

                <a asp-controller="Instructor" asp-action="RegisterInstructor" class="btn-portal">
                    <i class="fas fa-chalkboard-teacher"></i> Register as Instructor
                </a>

                <a asp-controller="Student" asp-action="RegisterStudent" class="btn-portal">
                    <i class="fas fa-graduation-cap"></i> Register as Student
                </a>
            </div>

            <div class="portal-footer">
                <div>&copy; @DateTime.Now.Year MITC QRCode Attendance.</div>
                <div class="mt-1">Built with heart <span class="heart-pulse">❤️‍🔥</span> by BAKARI Yazid Akanni <span class="heart-pulse">❤️‍🔥</span>.</div>
            </div>

        </div>
    </div>

    @await Html.PartialAsync("_PortalFooter")
</body>
</html>
