@using QRCodeAttendance.Models.DTOs.StudentDto
@model StudentDto
@{
    ViewData["Title"] = "Student Profile";
    Layout = null;
}

<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght=300;400;600;800&display=swap" rel="stylesheet">

    <style>
        *, *::before, *::after {
            box-sizing: border-box;
        }

        :root {
            --accent: #06b6d4; /* Cyan accent */
            --accent-glow: rgba(6, 182, 212, 0.3);
            --glass: rgba(15, 23, 42, 0.6);
            --glass-border: rgba(255, 255, 255, 0.12);
            --text-primary: #ffffff;
            --text-secondary: #94a3b8;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: 'Outfit', sans-serif;
            background: linear-gradient(45deg, rgba(15, 23, 42, 0.9), rgba(88, 28, 135, 0.4)),
                        url('https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=2564&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            min-height: 100vh;
            color: var(--text-primary);
        }

        .profile-page-shell {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }

        .student-portal {
            width: min(100%, 1200px);
            max-width: 1200px;
            min-height: 80vh;
            background: var(--glass);
            backdrop-filter: blur(20px) saturate(160%);
            -webkit-backdrop-filter: blur(20px) saturate(160%);
            border: 1px solid var(--glass-border);
            border-radius: 30px;
            display: flex;
            overflow: hidden;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            margin: 0 auto;
        }

        /* --- Sidebar Section --- */
        .sidebar {
            width: 320px;
            background: rgba(0, 0, 0, 0.2);
            padding: 3rem 2rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            border-right: 1px solid var(--glass-border);
        }

        .profile-hex {
            position: relative;
            width: 150px;
            height: 150px;
            margin: 0 auto 1.5rem auto;
        }

        .profile-avatar-initials {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            clip-path: polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%);
            border: 4px solid var(--accent);
            background: linear-gradient(135deg, var(--accent), #22d3ee);
            color: white;
            font-size: 3.2rem;
            font-weight: 800;
            line-height: 1;
            letter-spacing: 0;
            box-shadow: 0 18px 38px rgba(6, 182, 212, 0.28);
        }

        .level-badge {
            background: var(--accent);
            color: #000;
            padding: 4px 15px;
            border-radius: 20px;
            font-weight: 800;
            font-size: 0.75rem;
            text-transform: uppercase;
            margin-bottom: 1rem;
            box-shadow: 0 0 15px var(--accent-glow);
        }

        .profile-side-nav {
            width: 100%;
            margin-top: 2rem;
        }

        .nav-link-custom {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 12px 20px;
            color: var(--text-secondary);
            text-decoration: none;
            border-radius: 12px;
            margin-bottom: 8px;
            transition: 0.3s;
        }

        .nav-link-custom.active, .nav-link-custom:hover {
            background: rgba(255, 255, 255, 0.05);
            color: var(--accent);
        }

        /* --- Main Content Section --- */
        .main-content {
            flex: 1;
            padding: 3.5rem;
            overflow-y: auto;
        }

        .header-meta {
            margin-bottom: 3rem;
        }

        .matric-pill {
            font-family: monospace;
            background: rgba(255, 255, 255, 0.05);
            padding: 8px 16px;
            border-radius: 8px;
            border: 1px solid var(--glass-border);
            color: var(--accent);
            font-size: 1.1rem;
        }

        .data-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 1.5rem;
        }

        .data-card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--glass-border);
            padding: 1.5rem;
            border-radius: 20px;
            transition: transform 0.3s ease;
        }

        .data-card:hover {
            transform: translateY(-5px);
            background: rgba(255, 255, 255, 0.06);
        }

        .label {
            color: var(--text-secondary);
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 8px;
        }

        .value {
            font-weight: 600;
            font-size: 1.05rem;
        }

        .footer-timestamps {
            margin-top: 4rem;
            display: flex;
            justify-content: space-between;
            font-size: 0.8rem;
            color: var(--text-secondary);
            border-top: 1px solid var(--glass-border);
            padding-top: 1.5rem;
        }

        /* Mobile Optimization */
        @@media (max-width: 992px) {
            .profile-page-shell {
                align-items: flex-start;
                padding: 1rem;
            }

            .student-portal {
                width: 100%;
                min-height: 0;
                flex-direction: column;
                height: auto;
                border-radius: 24px;
                overflow: hidden; 
            }

            .sidebar {
                width: 100%;
                padding: 2.5rem 1.25rem;
                border-right: none;
                border-bottom: 1px solid var(--glass-border);
            }

            .main-content {
                padding: 2rem 1.25rem;
                overflow: visible;
            }

            .header-meta {
                display: block !important;
                margin-bottom: 1.5rem;
            }

            .header-meta .text-end {
                text-align: left !important;
                margin-top: 1rem;
            }

            .matric-pill {
                display: inline-flex;
                max-width: 100%;
                overflow-wrap: anywhere;
            }

            .data-grid {
                grid-template-columns: 1fr;
            }

            .footer-timestamps {
                flex-direction: column;
                gap: 1rem;
                margin-top: 2rem;
            }
        }

        @@media (max-width: 575.98px) {
            .profile-page-shell {
                padding: 0.3rem;
            }

            .student-portal {
                border-radius: 10px;
            }

            .profile-hex {
                width: 150px !important;
                height: 150px !important;
                margin-top: 1rem;
                margin-bottom: 0.9rem;
            }

            .profile-avatar-initials {
                clip-path: none;
                border-radius: 24px;
                font-size: 2.5rem;
            }

            .sidebar,
            .main-content {
                padding: 1.25rem;
            }

            .student-portal > .sidebar {
                padding-top: 2.75rem !important;
            }

            .nav-link-custom {
                padding: 0.8rem 1rem;
            }

            .data-card {
                padding: 1.15rem;
            }

            .value {
                overflow-wrap: anywhere;
            }
        }

        @@media (max-width: 575.98px) {
            body.with-portal-chrome.student-profile-page .student-portal {
                overflow: visible !important;
            }

            body.with-portal-chrome.student-profile-page .student-portal > .student-profile-sidebar {
                padding-top: 3.75rem !important;
                overflow: visible !important;
            }

            body.with-portal-chrome.student-profile-page .student-profile-sidebar .profile-hex {
                width: 135px !important;
                height: 135px !important;
                padding-top: 15px !important;
                margin-top: 15px !important;
                margin-bottom: 1.80rem !important;
                overflow: visible;
            }

            body.with-portal-chrome.student-profile-page .student-profile-sidebar .profile-avatar-initials {
                width: 100%;
                height: 100%;
                border-radius: 26px;
                clip-path: none;
                background: linear-gradient(135deg, #06b6d4, #22d3ee);
                box-shadow: 0 18px 34px rgba(6, 182, 212, 0.28);
            }
        }
    </style>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="with-portal-chrome student-profile-page">
    @await Html.PartialAsync("_PortalHeader")

    <main class="profile-page-shell">
        <div class="student-portal">
            <div class="sidebar student-profile-sidebar">
                <div class="profile-hex">
                    <div class="profile-avatar-initials" aria-label="Student initials">
                        @($"{(string.IsNullOrWhiteSpace(Model.FirstName) ? "S" : Model.FirstName.Trim()[0].ToString())}{(string.IsNullOrWhiteSpace(Model.LastName) ? "" : Model.LastName.Trim()[0].ToString())}")
                    </div>
                </div>
                <div class="level-badge">@Model.StudentLevel.GetDescription()</div>
                <h4 class="mb-0 fw-bold">@Model.FirstName @Model.LastName</h4>
                <p class="small text-secondary mb-4">@Model.Department</p>

                <a asp-controller="Student" asp-action="EditStdProfile" class="btn btn-sm rounded-pill px-4 mb-4" 
                   style="background: rgba(255,255,255,0.1); border: 1px solid var(--glass-border); color: var(--accent); font-weight: 600; transition: 0.3s;">
                    <i class="fas fa-user-edit me-2"></i> Edit Profile
                </a>

                <nav class="profile-side-nav">
                    <a asp-controller="Student" asp-action="StudentDashboard" class="nav-link-custom"><i class="fa-solid fa-gauge-high"></i> Dashboard</a>
                    <a asp-controller="Student" asp-action="StdProfile" class="nav-link-custom active"><i class="fa-solid fa-id-card"></i> Profile Overview</a>
                    <a asp-controller="Student" asp-action="AttendanceReport" class="nav-link-custom"><i class="fa-solid fa-qrcode"></i> My Attendances</a>
                    <a asp-controller="Student" asp-action="Courses" class="nav-link-custom"><i class="fa-solid fa-graduation-cap"></i> Courses</a>
                    <a asp-controller="Student" asp-action="Settings" class="nav-link-custom"><i class="fa-solid fa-user-gear"></i> Settings</a>
                </nav>
            </div>

            <div class="main-content">
                <div class="header-meta d-flex justify-content-between align-items-end">
                    <div>
                        <h2 class="fw-800 mb-1">Student Record</h2>
                        @{
                            var now = DateTime.Now;
                            int startYear = (now.Month < 8) ? now.Year - 1 : now.Year;
                            int endYear = startYear + 1;
                        }
                        <p class="text-secondary mb-0">Academic Session @startYear/@endYear</p>
                    </div>
                    <div class="text-end">
                        <div class="label">Matriculation Number</div>
                        <span class="matric-pill">@Model.MatricNumber</span>
                    </div>
                </div>

                <div class="data-grid">
                    <div class="data-card">
                        <div class="label">Full Legal Name</div>
                        <div class="value">@Model.FullName</div>
                    </div>
                    <div class="data-card">
                        <div class="label">Primary Email</div>
                        <div class="value">@Model.Email</div>
                    </div>
                    <div class="data-card">
                        <div class="label">Contact Number</div>
                        <div class="value">@Model.PhoneNumber</div>
                    </div>
                    <div class="data-card">
                        <div class="label">Gender</div>
                        <div class="value">@Model.Gender</div>
                    </div>
                    <div class="data-card">
                        <div class="label">Birth Date</div>
                        <div class="value">@Model.DateOfBirth.ToString("dd MMM, yyyy")</div>
                    </div>
                    <div class="data-card">
                        <div class="label">Residential Address</div>
                        <div class="value">@Model.Address</div>
                    </div>
                </div>

                <hr style="border-color: rgba(255,255,255,0.1); margin: 2rem 0;">

                <div class="footer-timestamps">
                    <div class="timestamp-item d-flex gap-3 align-items-center">
                        <div class="timestamp-icon">
                            <i class="fa-solid fa-user-plus"></i>
                        </div>
                        <div>
                            <div class="timestamp-label" style="font-size: 0.7rem; uppercase; color: var(--text-secondary)">Member Since</div>
                            <div class="timestamp-value fw-semibold">
                                @Model.CreatedDate.ToLocalTime().ToString("MMM dd, yyyy – hh:mm tt")
                            </div>
                        </div>
                    </div>

                    <div class="timestamp-item d-flex gap-3 align-items-center">
                        <div class="timestamp-icon">
                            <i class="fa-solid fa-user-pen"></i>
                        </div>
                        <div>
                            <div class="timestamp-label" style="font-size: 0.7rem; uppercase; color: var(--text-secondary)">Profile Updated</div>
                            <div class="timestamp-value fw-semibold">
                                <span class="@(Model.UpdatedDate == default(DateTime) ? "text-warning" : "")">
                                    @(Model.UpdatedDate == default(DateTime) 
                                        ? "Never updated" 
                                        : Model.UpdatedDate.ToLocalTime().ToString("MMM dd, yyyy – hh:mm tt"))
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    @await Html.PartialAsync("_PortalFooter")
</body>
</html>
