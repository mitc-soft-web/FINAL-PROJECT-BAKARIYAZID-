@using QRCodeAttendance.Models.Enums;
@model QRCodeAttendance.Models.DTOs.Student.CreateStudentRequestModel

@{
    ViewData["Title"] = "Student Enrollment";
    Layout = null;
}

<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #6366f1;
            --primary-light: #818cf8;
            --glass-bg: rgba(255, 255, 255, 0.12);
            --glass-border: rgba(255, 255, 255, 0.18);
            --text-main: #ffffff;
            --text-muted: rgba(255, 255, 255, 0.7);
            --transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body {
            background: linear-gradient(rgba(15, 23, 42, 0.75), rgba(15, 23, 42, 0.75)), 
                        url('https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?auto=format&fit=crop&q=80&w=1920');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            min-height: 100vh;
            font-family: 'Inter', sans-serif;
            color: var(--text-main);
            padding: 2rem 1rem;
        }

        .student-register-shell {
            min-height: 100vh;
            display: flex;
            align-items: center;
            width: 100%;
        }

        .glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--glass-border);
            border-radius: 28px;
            width: 100%;
            max-width: 850px;
            padding: 3.5rem;
            margin: 2rem auto;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            animation: fadeIn 0.8s ease-out;
        }

        .header-section {
            text-align: center;
            margin-bottom: 3rem;
        }

        .brand-logo {
            width: 70px;
            height: 70px;
            background: var(--primary);
            color: white;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            font-size: 1.8rem;
            box-shadow: 0 10px 20px rgba(99, 102, 241, 0.3);
        }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1.5rem;
        }

        .full-width { grid-column: span 2; }

        .input-field {
            position: relative;
        }

        .input-field input, .input-field select {
            width: 100%;
            padding: 14px 16px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 14px;
            outline: none;
            color: white;
            font-size: 0.95rem;
            transition: var(--transition);
        }

        .input-field input[type="date"]::-webkit-calendar-picker-indicator {
            filter: invert(1);
        }
        
        .input-field select option {
            background: #1e293b;
            color: white;
        }

        .input-field label {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            pointer-events: none;
            transition: var(--transition);
            font-size: 0.95rem;
        }

        .input-field input:focus, .input-field select:focus {
            background: rgba(255, 255, 255, 0.1);
            border-color: var(--primary-light);
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.15);
        }

        .input-field input:focus + label,
        .input-field input:not(:placeholder-shown) + label,
        .input-field select:focus + label,
        .input-field select:not([value=""]):valid + label {
            top: -10px;
            left: 12px;
            font-size: 0.75rem;
            color: var(--primary-light);
            font-weight: 700;
            background: transparent;
            padding: 0 5px;
        }

        .btn-submit {
            width: 100%;
            margin-top: 2.5rem;
            padding: 1.1rem;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 14px;
            font-weight: 800;
            letter-spacing: 0.5px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            transition: var(--transition);
        }

        .btn-submit:hover {
            background: var(--primary-light);
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(99, 102, 241, 0.4);
        }

        .footer-action {
            margin-top: 2.5rem;
            text-align: center;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            padding-top: 2rem;
        }

        .slide-link {
            color: var(--primary-light);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9rem;
            transition: var(--transition);
        }

        .slide-link:hover {
            color: white;
            letter-spacing: 0.5px;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @@media (max-width: 768px) {
            .form-grid { grid-template-columns: 1fr; }
            .full-width { grid-column: span 1; }
            .glass-card { padding: 2rem; }
        }

        .input-error {
            border-color: #ef4444 !important;
            background: rgba(239, 68, 68, 0.05) !important;
        }
    </style>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="with-portal-chrome">
    @await Html.PartialAsync("_PortalHeader")
    <main class="student-register-shell">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-xl-8 col-lg-9 col-md-11">
                    <div class="glass-card">
                        <div class="header-section">
                            <div class="brand-logo">
                                <i class="fas fa-graduation-cap"></i>
                            </div>
                            <h2 class="fw-800">Student Enrollment</h2>
                            <p class="text-muted">Register your details for QRCodeAttendance</p>
                        </div>
                        @if (TempData["Alert"] != null)
                        {
                            <div class="alert alert-custom text-center mb-4">
                                @TempData["Alert"]
                            </div>
                        }
                        <form asp-controller="Student" asp-action="RegisterStudent" method="post">
                            @Html.AntiForgeryToken()
                            <div class="form-grid">
                                <div class="input-field">
                                    <input asp-for="FirstName" placeholder=" " required />
                                    <label>First Name</label>
                                </div>

                                <div class="input-field">
                                    <input asp-for="LastName" placeholder=" " required />
                                    <label>Last Name</label>
                                </div>
                                
                                <div class="input-field">
                                    <input asp-for="MatricNumber" placeholder=" " required />
                                    <label>Matric Number</label>
                                </div>

                                <div class="input-field">
                                    <input asp-for="DateOfBirth" type="date" required />
                                    <label>Date of Birth</label>
                                </div>

                                <div class="input-field full-width">
                                    <input asp-for="Address" placeholder=" " required />
                                    <label>Residential Address</label>
                                </div>

                                <div class="input-field">
                                    <select asp-for="Gender" asp-items="@Html.GetEnumSelectList<Gender>()" required>
                                        <option value="" disabled selected></option>
                                    </select>
                                    <label>Gender</label>
                                </div>

                                <div class="input-field">
                                    <select asp-for="Department" asp-items="@Html.GetEnumSelectList<Departments>()" required>
                                        <option value="" disabled selected></option>
                                    </select>
                                    <label>Department</label>
                                </div>

                                <div class="input-field">
                                    <select asp-for="StudentLevel" asp-items="@Html.GetEnumSelectList<StudentLevel>()" required>
                                        <option value="" disabled selected></option>
                                    </select>
                                    <label>Level</label>
                                </div>

                                <div class="input-field">
                                    <input asp-for="PhoneNumber" placeholder=" " required />
                                    <label>Phone Number</label>
                                </div>

                                <div class="input-field full-width">
                                    <input asp-for="Email" type="email" placeholder=" " required />
                                    <label>Email Address</label>
                                </div>

                                <div class="input-field full-width password-strength-field" data-password-strength>
                                    <input asp-for="PasswordHash" type="password" placeholder=" " required autocomplete="new-password" data-password-strength-input aria-describedby="student-password-strength student-password-requirements" />
                                    <label>Enter Your Password <span class="required-star">*</span></label>
                                    <button class="password-toggle-button" type="button" data-password-toggle aria-label="Show password" aria-pressed="false">
                                        <i class="fas fa-eye-slash"></i>
                                    </button>
                                    <div class="password-strength-meter" aria-hidden="true">
                                        <span></span> <span></span> <span></span>
                                    </div>
                                    <p class="password-strength-label">Password Strength: <span id="student-password-strength" data-password-strength-label></span></p>
                                    <ul class="password-requirements" id="student-password-requirements" data-password-requirements></ul>
                                </div>
                                
                                <div class="input-field full-width">
                                    <input asp-for="ConfirmPassword" type="password" placeholder=" " required autocomplete="new-password" />
                                    <label>Confirm Password</label>
                                </div>
                            </div>

                            <button type="submit" class="btn-submit">
                                <span>Enroll Now</span>
                                <i class="fas fa-arrow-right"></i>
                            </button>
                        </form>

                        <div class="footer-action">
                            <div class="mb-2">
                                <span class="small opacity-50">Not a Student?</span> 
                                <a href="/Instructor/RegisterInstructor" class="slide-link ms-2">Instructor Portal <i class="fas fa-chevron-right small"></i></a>
                            </div>
                            <div>
                                <span class="small opacity-50">Already enrolled?</span> 
                                <a href="/User/Login" class="slide-link ms-2">Login Here <i class="fas fa-chevron-right small"></i></a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
    @await Html.PartialAsync("_PortalFooter")
    <script src="~/js/password-strength.js" asp-append-version="true"></script>
</body>
</html>
