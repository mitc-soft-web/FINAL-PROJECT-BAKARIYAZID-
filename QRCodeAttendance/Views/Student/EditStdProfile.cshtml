@using QRCodeAttendance.Models.DTOs.Student
@using QRCodeAttendance.Models.Enums
@model UpdateStudentRequestModel
@{
     ViewData["Title"] = "Edit Student Profile";
    Layout = null;
}

<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --accent: #06b6d4; /* Cyan focus for Students */
            --glass: rgba(255, 255, 255, 0.03);
            --glass-border: rgba(255, 255, 255, 0.1);
            --text-muted: #94a3b8;
        }

        body {
            background: #020617;
            background-image: 
                radial-gradient(at 0% 0%, rgba(6, 182, 212, 0.15) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(59, 130, 246, 0.1) 0px, transparent 50%);
            min-height: 100vh;
            font-family: 'Outfit', sans-serif;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1.5rem;
        }

        .student-edit-shell {
            min-height: calc(100dvh - var(--portal-header-height, 76px) - var(--portal-footer-height, 56px));
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: clamp(1rem, 3vw, 2rem);
        }

        .main-card {
            background: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(30px) saturate(200%);
            border: 1px solid var(--glass-border);
            border-radius: 32px;
            overflow: hidden;
            width: 100%;
            max-width: 1100px;
            box-shadow: 0 50px 100px -20px rgba(0, 0, 0, 0.5);
        }

        /* Sidebar within the card */
        .info-panel {
            background: rgba(255, 255, 255, 0.03);
            border-right: 1px solid var(--glass-border);
            padding: 3rem;
            text-align: center;
        }

        .form-panel { padding: 3rem; }

        .profile-preview {
            width: 120px;
            height: 120px;
            border-radius: 24px;
            background: linear-gradient(135deg, var(--accent), #3b82f6);
            margin: 0 auto 1.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            font-weight: 800;
            box-shadow: 0 20px 40px rgba(6, 182, 212, 0.3);
        }

        .input-group-custom {
            background: var(--glass);
            border: 1px solid var(--glass-border);
            border-radius: 16px;
            padding: 0.5rem 1rem;
            margin-bottom: 1.25rem;
            transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .input-group-custom:focus-within {
            border-color: var(--accent);
            background: rgba(255, 255, 255, 0.07);
            transform: translateY(-2px);
            box-shadow: 0 10px 20px -5px rgba(0, 0, 0, 0.3);
        }

        .label-style {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--accent);
            margin-bottom: 4px;
            display: block;
        }

        input, select {
            background: transparent !important;
            border: none !important;
            color: white !important;
            width: 100%;
            font-weight: 500;
            outline: none;
        }

        input::placeholder { color: #475569; }

        .btn-update {
            background: linear-gradient(135deg, var(--accent), #3b82f6);
            border: none;
            border-radius: 16px;
            padding: 1rem;
            width: 100%;
            color: white;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: 0.3s;
            margin-top: 1rem;
        }

        .btn-update:hover {
            filter: brightness(1.2);
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(6, 182, 212, 0.4);
        }

        .btn-stack {
            display: flex;
            gap: 1rem;
            margin-top: 2rem;
        }

        .btn-cancel {
            flex: 1;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--glass-border);
            border-radius: 16px;
            padding: 1rem;
            color: white;
            font-weight: 600;
            text-decoration: none;
            text-align: center;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 0.9rem;
            transition: 0.3s all ease;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .btn-cancel:hover {
            background: rgba(255, 255, 255, 0.1);
            color: white;
            border-color: rgba(255, 255, 255, 0.2);
            transform: translateY(-2px);
        }

        .btn-update {
            flex: 2; 
            margin-top: 0 !important; 
        }

            @@media (max-width: 991px) {
                .student-edit-shell { align-items: flex-start; }
                .info-panel { border-right: none; border-bottom: 1px solid var(--glass-border); padding: 2rem; }
                .form-panel { padding: 2rem; }
            }

            @@media (max-width: 576px) {
                .btn-stack {
                    flex-direction: column;
                }

                .btn-update {
                    order: 1;
                    width: 100%;
                }

                .btn-cancel {
                    order: 2;
                    width: 100%;
                }
            }
    </style>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="with-portal-chrome">
    @await Html.PartialAsync("_PortalHeader")

    <main class="student-edit-shell">
    <div class="main-card">
        <div class="row g-0">
            <!-- Left Side: Profile Identity -->
            <div class="col-lg-4 info-panel">
                <div class="profile-preview">
                    @((Model.FirstName ?? "S")[0])
                </div>
                <h2 class="fw-bold mb-1">@Model.FirstName @Model.LastName</h2>
            <p class="mb-4 fw-bold" style="color: rgba(103, 232, 249, 0.7); font-size: 0.85rem; letter-spacing: 0.5px;">
                Student ID: #@((Model.Email ?? string.Empty).Split('@')[0])
            </p>

            <div class="p-3 rounded-4 mb-4" style="background: rgba(6, 182, 212, 0.1); border: 1px solid rgba(6, 182, 212, 0.2);">
                <span class="label-style d-block mb-1">Current Level</span>
                <h5 class="mb-0 fw-bold">@Model.StudentLevel.GetDescription()</h5>
            </div>
            
                <a asp-action="StdProfile" class="text-decoration-none small fw-bold d-inline-block mb-3 profile-back-link">
                    <i class="fas fa-arrow-left me-1"></i> Back to Profile
                </a>
        </div>

            <!-- Right Side: Edit Form -->
            <div class="col-lg-8 form-panel">
                <h4 class="mb-4 fw-bold">Academic Information</h4>
                <form asp-controller="Student" asp-action="EditStdProfile" method="post">
                    <div class="row">
                        <div class="col-md-6">
                            <span class="label-style">First Name</span>
                            <div class="input-group-custom">
                                <input asp-for="FirstName" placeholder="First Name" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <span class="label-style">Last Name</span>
                            <div class="input-group-custom">
                                <input asp-for="LastName" placeholder="Last Name" />
                            </div>
                        </div>
                        <div class="col-md-12">
                            <span class="label-style">Institutional Email</span>
                            <div class="input-group-custom">
                                <input asp-for="Email" type="email" readonly style="opacity: 0.6;" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <span class="label-style">Department</span>
                            <div class="input-group-custom">
                                <select asp-for="Department" asp-items="Html.GetEnumSelectList<Departments>()"></select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <span class="label-style">Student Level</span>
                            <div class="input-group-custom">
                                <select asp-for="StudentLevel" asp-items="Html.GetEnumSelectList<StudentLevel>()"></select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <span class="label-style">Date of Birth</span>
                            <div class="input-group-custom">
                                <input asp-for="DateOfBirth" type="date" value="@Model.DateOfBirth.ToString("yyyy-MM-dd")" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <span class="label-style">Gender</span>
                            <div class="input-group-custom">
                                <select asp-for="Gender" asp-items="Html.GetEnumSelectList<Gender>()"></select>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <span class="label-style">Home Address</span>
                            <div class="input-group-custom">
                                <input asp-for="Address" placeholder="123 Cyber St, Digital City" />
                            </div>
                        </div>
                    </div>
                    <div class="btn-stack">
                        <a asp-action="StdProfile" class="btn-cancel"><i class="fas fa-times me-2"></i> Discard</a>
                        <button type="submit" class="btn-update"><i class="fas fa-check-circle me-2"></i>Save Student Record</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    </main>

    @await Html.PartialAsync("_PortalFooter")
</body>
</html>
