@using QRCodeAttendance.Models.DTOs.Instructor
@using QRCodeAttendance.Models.DTOs.InstructorDto
@model InstructorDto
@{
    ViewData["Title"] = "Instructor Profile";
    Layout = null; 
}

<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #10b981;
            --surface: rgba(15, 23, 42, 0.7);
            --border: rgba(255, 255, 255, 0.08);
            --text-main: #f8fafc;
            --text-dim: #94a3b8;
        }

        body {
            background: radial-gradient(circle at top left, rgba(16, 185, 129, 0.1), transparent),
                        radial-gradient(circle at bottom right, rgba(6, 182, 212, 0.1), transparent),
                        url('https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?q=80&w=2000&auto=format&fit=crop');
            background-size: cover;
            background-attachment: fixed;
            min-height: 100vh;
            color: var(--text-main);
            font-family: 'Plus Jakarta Sans', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }

        .profile-page-shell {
            min-height: calc(100dvh - var(--portal-header-height, 76px) - var(--portal-footer-height, 56px));
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: clamp(1rem, 3vw, 2rem);
        }

        .profile-container {
            width: 100%;
            max-width: 1100px;
            margin: 0 auto;
            background: var(--surface);
            backdrop-filter: blur(25px) saturate(180%);
            border: 1px solid var(--border);
            border-radius: 40px;
            display: flex;
            overflow: hidden;
            box-shadow: 0 40px 100px rgba(0,0,0,0.4);
        }

        .profile-sidebar {
            width: 340px;
            background: rgba(255, 255, 255, 0.03);
            border-right: 1px solid var(--border);
            padding: 3rem 2rem;
            text-align: center;
        }

        .avatar-container {
            position: relative;
            width: 140px;
            height: 140px;
            margin: 0 auto 1.5rem;
        }

        .avatar-image {
            width: 100%;
            height: 100%;
            border-radius: 35px;
            object-fit: cover;
            border: 3px solid var(--primary);
            padding: 5px;
            background: var(--surface);
        }

        .status-badge {
            position: absolute;
            bottom: 5px;
            right: 5px;
            width: 20px;
            height: 20px;
            background: #10b981;
            border: 3px solid #1e293b;
            border-radius: 50%;
        }

        .nav-menu {
            margin-top: 3rem;
            list-style: none;
            padding: 0;
            text-align: left;
        }

        .nav-item {
            padding: 12px 20px;
            border-radius: 15px;
            margin-bottom: 8px;
            cursor: pointer;
            transition: 0.3s;
            color: var(--text-dim);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .nav-item.active {
            background: rgba(16, 185, 129, 0.15);
            color: var(--primary);
            font-weight: 600;
        }

        .nav-item:hover:not(.active) {
            background: rgba(255, 255, 255, 0.05);
            color: white;
        }

        .profile-content {
            flex: 1;
            padding: 4rem;
        }

        .section-title {
            font-weight: 800;
            letter-spacing: -1px;
            margin-bottom: 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .info-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 2rem;
        }

        .info-card {
            background: rgba(255, 255, 255, 0.03);
            padding: 1.5rem;
            border-radius: 20px;
            border: 1px solid var(--border);
            transition: 0.3s;
        }

        .info-card:hover {
            background: rgba(255, 255, 255, 0.06);
            border-color: rgba(16, 185, 129, 0.3);
        }

        .info-label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-dim);
            margin-bottom: 0.5rem;
        }

        .info-value {
            font-weight: 600;
            font-size: 1.1rem;
        }

        .btn-edit {
            background: var(--primary);
            color: #0f172a;
            border: none;
            padding: 10px 24px;
            border-radius: 12px;
            font-weight: 700;
            font-size: 0.9rem;
            transition: 0.3s;
        }

        .btn-edit:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(16, 185, 129, 0.2);
        }

        /* Expert Meta Styling */
        .profile-history {
            margin-top: 3rem;
            padding-top: 2rem;
            border-top: 1px solid var(--border);
            display: flex;
            gap: 3rem;
        }

        .history-item {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .history-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--border);
            display: grid;
            place-items: center;
            color: var(--primary);
        }

        .history-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-dim);
            margin-bottom: 2px;
        }

        .history-value {
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--text-main);
        }

        .never-updated {
            color: #fb7185;
            font-style: italic;
            font-weight: 400;
        }

        .back-to-dashboard {
            position: fixed;
            left: 2rem;
            top: 2rem;
            background: var(--surface);
            backdrop-filter: blur(15px);
            border: 1px solid var(--border);
            padding: 9px 100px;
            border-radius: 16px;
            color: var(--text-main);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: 600;
            font-size: 0.9rem;
            transition: all 0.3s ease;
            z-index: 1000;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }

        .back-to-dashboard:hover {
            background: rgba(255, 255, 255, 0.1);
            color: var(--primary);
            transform: translateX(5px);
            border-color: var(--primary);
        }

        .back-to-dashboard i {
            font-size: 1.1rem;
            transition: transform 0.3s ease;
        }

        .back-to-dashboard:hover i {
            transform: translateX(-3px);
        }

        @@media (max-width: 576px) {
            .back-to-dashboard span { display: none; }
            .back-to-dashboard { padding: 12px; left: 1rem; top: 1rem; }
        }

        @@media (max-width: 992px) {
            .profile-page-shell { align-items: flex-start; }
            .profile-container { flex-direction: column; }
            .profile-sidebar { width: 100%; border-right: none; border-bottom: 1px solid var(--border); }
            .info-grid { grid-template-columns: 1fr; }
            .profile-history { flex-direction: column; gap: 1.5rem; }
        }
    </style>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="with-portal-chrome">
    @await Html.PartialAsync("_PortalHeader")

    <main class="profile-page-shell">
    <div class="profile-container">
        <div class="profile-sidebar">
                <div class="avatar-container">
                <img src="https://ui-avatars.com/api/?name=@(Model.FirstName)+@(Model.LastName)&background=10b981&color=fff&size=128" alt="Profile" class="avatar-image">
                <div class="status-badge"></div>
            </div>

            
            <h3 class="fw-800 mb-1">Eng. @Model.LastName</h3>
            <p class="text-dim small mb-4">Instructor ID: #INST-@(Model.LastName.Substring(0,2).ToUpper())-2026</p>

            <ul class="nav-menu">

                <li>
                    <a asp-controller="Instructor" asp-action="InstructorDashboard" class="nav-item back-button">
                        <i class="fas fa-chevron-left"></i> Back to Dashboard
                    </a>
                </li>

                <li class="nav-item active">
                    <i class="fas fa-user-circle"></i> Personal Info
                </li>
                <li class="nav-item">
                    <i class="fas fa-book"></i> Assigned Courses
                </li>
                <li class="nav-item">
                    <a asp-controller="Instructor" asp-action="Report" class="nav-item">
                         <i class="fas fa-file-alt"></i> Attendance Reports 
                        @* <i class="fas fa-qrcode"></i> Attendance Reports *@
                    </a>
                </li>
                <li class="nav-item">
                    <i class="fas fa-cog"></i> Account Settings
                </li>
            </ul>
        </div>

        <div class="profile-content">
            <div class="section-title">
                <h2 class="h3 mb-0">General Information</h2>
    
            <a asp-controller="Instructor" asp-action="EditInsProfile" class="text-decoration-none">
                <button class="btn-edit" type="button">
                    <i class="fas fa-pen-nib me-2"></i> Edit Profile
                </button>
            </a>

        </div>

            <div class="info-grid">
                <div class="info-card">
                    <div class="info-label">Full Name</div>
                    <div class="info-value">@Model.FirstName @Model.LastName</div>
                </div>

                <div class="info-card">
                    <div class="info-label">Institutional Email</div>
                    <div class="info-value">@Model.Email</div>
                </div>

                <div class="info-card">
                    <div class="info-label">Department</div>
                    <div class="info-value text-primary">@Model.Department</div>
                </div>

                <div class="info-card">
                    <div class="info-label">Phone Number</div>
                    <div class="info-value">@Model.PhoneNumber</div>
                </div>

                <div class="info-card">
                    <div class="info-label">Gender</div>
                    <div class="info-value">@Model.Gender</div>
                </div>

                <div class="info-card">
                    <div class="info-label">Date of Birth</div>
                    <div class="info-value">@Model.DateOfBirth.ToString("MMMM dd, yyyy")</div>
                </div>
            </div>

            <div class="mt-5 p-4" style="background: rgba(16, 185, 129, 0.05); border-radius: 25px; border: 1px dashed var(--primary);">
                <div class="d-flex align-items-center gap-3">
                    <div style="background: var(--primary); color: #0f172a; width: 45px; height: 45px; border-radius: 12px; display: grid; place-items: center;">
                        <i class="fas fa-info-circle fa-lg"></i>
                    </div>
                    <div>
                        <h6 class="mb-1 fw-bold">Address Information</h6>
                        <p class="mb-0 text-dim small">@Model.Address</p>
                    </div>
                </div>
            </div>

            <div class="profile-history">
                <div class="history-item">
                    <div class="history-icon">
                        <i class="fas fa-user-plus"></i>
                    </div>
                    <div>
                        <div class="history-label">Member Since</div>
                        <div class="history-value">@Model.CreatedDate.ToLocalTime().ToString("MMM dd, yyyy - hh:mm tt")</div>
                    </div>
                </div>

                <div class="history-item">
                    <div class="history-icon">
                        <i class="fas fa-user-edit"></i>
                    </div>
                    <div>
                        <div class="history-label">Profile Updated</div>
                        <div class="history-value">
                            @if (Model.UpdatedDate == Model.CreatedDate || Model.UpdatedDate == default(DateTime))
                            {
                                <span class="never-updated">Never updated</span>
                            }
                            else
                            {
                                @Model.UpdatedDate.ToLocalTime().ToString("MMM dd, yyyy - hh:mm tt")
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    </main>

    @await Html.PartialAsync("_PortalFooter")
</body>
</html>
