@using QRCodeAttendance.Models.Enums
@model QRCodeAttendance.Models.DTOs.Instructor.CreateInstructorRequestModel

@{
    ViewData["Title"] = "Register Instructor";
    Layout = null; 
}

<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - QRCodeAttendance</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary-accent: #6366f1; 
            --glass-bg: rgba(255, 255, 255, 0.15);
            --glass-border: rgba(255, 255, 255, 0.2);
            --text-main: #ffffff;
        }

        body {
            /* Using a tech-focused dark background that makes glass pop */
            background: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), 
                        url('https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&fit=crop&q=80&w=1920');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            min-height: 100vh;
            font-family: 'Inter', sans-serif;
            display: flex;
            align-items: center;
            color: var(--text-main);
        }

        .glass-container {
            background: var(--glass-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
            padding: 3rem;
            margin: 2rem 0;
        }

        .form-label {
            font-weight: 500;
            font-size: 0.85rem;
            color: rgba(255, 255, 255, 0.9);
            margin-bottom: 0.5rem;
        }

        .form-control, .form-select {
            background: rgba(255, 255, 255, 0.07);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: white !important;
            border-radius: 12px;
            padding: 0.75rem 1rem;
            transition: all 0.3s ease;
        }

        .form-control::placeholder {
            color: rgba(255, 255, 255, 0.4);
        }

        .form-control:focus, .form-select:focus {
            background: rgba(255, 255, 255, 0.12);
            border-color: var(--primary-accent);
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.2);
            outline: none;
        }

        .form-select option {
            background: #1e1e2e;
            color: white;
        }

        .btn-register {
            background: var(--primary-accent);
            border: none;
            padding: 0.9rem;
            font-weight: 700;
            border-radius: 12px;
            color: white;
            letter-spacing: 0.5px;
            transition: all 0.3s transform ease;
            margin-top: 1.5rem;
        }

        .btn-register:hover {
            background: #4f46e5;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(99, 102, 241, 0.4);
        }

        .text-danger {
            font-size: 0.75rem;
            font-weight: 500;
        }

        .bounce-link {
            color: var(--primary-accent);
            text-decoration: none;
            font-weight: 600;
            transition: 0.3s;
        }

        .bounce-link:hover {
            color: #818cf8;
            text-decoration: underline;
        }

        .alert-custom {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border: 1px solid var(--glass-border);
            color: white;
            border-radius: 12px;
        }
    </style>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="with-portal-chrome">
    @await Html.PartialAsync("_PortalHeader")
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xl-7 col-lg-8 col-md-10">
                
                @if (TempData["Alert"] != null)
                {
                    <div class="alert alert-custom text-center mb-4">
                        @TempData["Alert"]
                    </div>
                }

                <div class="glass-container">
                    <div class="text-center mb-5">
                        <div class="mb-3">
                            <i class="bi bi-qr-code-scan" style="font-size: 3rem; color: var(--primary-accent);"></i>
                        </div>
                        <h2 class="fw-bold">Instructor Portal</h2>
                        <p style="color: rgba(255, 255, 255, 0.6);">Join the QRCodeAttendance ecosystem</p>
                    </div>

                    <form asp-controller="Instructor" asp-action="RegisterInstructor" method="post">
                        @Html.AntiForgeryToken()

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label">First Name</label>
                                <input asp-for="FirstName" class="form-control" placeholder="John" required />
                                <span asp-validation-for="FirstName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Last Name</label>
                                <input asp-for="LastName" class="form-control" placeholder="Doe" required />
                                <span asp-validation-for="LastName" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Date of Birth</label>
                                <input asp-for="DateOfBirth" type="date" class="form-control" required />
                                <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Gender</label>
                                <select asp-for="Gender" asp-items="@Html.GetEnumSelectList(typeof(Gender))" class="form-select" required>
                                    <option value="">-- Select Gender --</option>
                                </select>
                                <span asp-validation-for="Gender" class="text-danger"></span>
                            </div>

                            <div class="col-md-12">
                                <label class="form-label">Department</label>
                                <select asp-for="Department" asp-items="@Html.GetEnumSelectList(typeof(Departments))" class="form-select" required>
                                    <option value="">-- Select Department --</option>
                                </select>
                                <span asp-validation-for="Department" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Phone Number</label>
                                <input asp-for="PhoneNumber" class="form-control" placeholder="+234..." required />
                                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                            </div>
                            
                            <div class="col-md-6">
                                <label class="form-label">Address</label>
                                <input asp-for="Address" class="form-control" placeholder="Office/Home Address" />
                                <span asp-validation-for="Address" class="text-danger"></span>
                            </div>

                            <div class="col-12">
                                <label class="form-label">Institutional Email</label>
                                <input asp-for="Email" type="email" class="form-control" placeholder="name@university.edu" required />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <div class="col-12">
                                <label class="form-label">Admin Invitation Code</label>
                                <input asp-for="InvitationCode" class="form-control text-uppercase" placeholder="INS-123456" required />
                                <span asp-validation-for="InvitationCode" class="text-danger"></span>
                            </div>

                            <div class="col-md-12 password-strength-field" data-password-strength>
                                <label class="form-label">Enter Your Password <span class="required-star">*</span></label>
                                <input asp-for="PasswordHash" type="password" class="form-control" required autocomplete="new-password" data-password-strength-input aria-describedby="instructor-password-strength instructor-password-requirements" />
                                <button class="password-toggle-button" type="button" data-password-toggle aria-label="Show password" aria-pressed="false">
                                    <i class="bi bi-eye-slash"></i>
                                </button>
                                <div class="password-strength-meter" aria-hidden="true">
                                    <span></span> <span></span> <span></span>
                                </div>
                                <p class="password-strength-label">Password Strength: <span id="instructor-password-strength" data-password-strength-label></span></p>
                                <ul class="password-requirements" id="instructor-password-requirements" data-password-requirements></ul>
                                <span asp-validation-for="PasswordHash" class="text-danger"></span>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label">Confirm Password</label>
                                <input asp-for="ConfirmPassword" type="password" class="form-control" required autocomplete="new-password" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                            </div>

                            <div class="col-12">
                                <button type="submit" class="btn btn-register w-100">
                                    <i class="bi bi-person-plus-fill me-2"></i>Complete Registration
                                </button>
                            </div>
                        </div>
                    </form>

                    <div class="text-center mt-5 pt-4 border-top border-secondary">
                        <p class="small mb-2" style="color: rgba(255,255,255,0.5);">Manage your classroom with ease</p>
                        <div class="d-flex justify-content-center gap-4">
                            <a href="/Student/RegisterStudent" class="bounce-link small">Student Portal</a>
                            <a href="/User/Login" class="bounce-link small">Sign In</a>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
    @await Html.PartialAsync("_PortalFooter")
    <script src="~/js/password-strength.js" asp-append-version="true"></script>
</body>
</html>
