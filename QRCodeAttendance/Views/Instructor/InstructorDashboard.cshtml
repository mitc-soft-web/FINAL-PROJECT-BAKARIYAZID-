    <script>
        function generateQR(token, expiry){
            document.getElementById("qrcode").innerHTML = "";
            new QRCode(document.getElementById("qrcode"), {
                text: token,
                width: 150,
                height: 150,
                colorDark : "#0f172a",
                colorLight : "#ffffff"
            });
            startTimer(expiry);
        }

        function startTimer(expiry) {
            let end = new Date(expiry).getTime();
            if(window.timerInterval) clearInterval(window.timerInterval);
            window.timerInterval = setInterval(() => {
                let now = new Date().getTime();
                let distance = end - now;
                if (distance < 0) {
                    clearInterval(window.timerInterval);
                    document.getElementById("timer").innerText = "EXPIRED";
                    return;
                }
                let m = Math.floor(distance / (1000 * 60));
                let s = Math.floor((distance % (1000 * 60)) / 1000);
                document.getElementById("timer").innerText = `${m}m ${s}s`;
            }, 1000);
        }
    </script>
    <script>
        (() => {
            const toggle = document.querySelector(".dashboard-menu-toggle");
            const nav = document.getElementById("instructorDashboardNav");

            if (!toggle || !nav) {
                return;
            }

            toggle.addEventListener("click", () => {
                const isOpen = nav.classList.toggle("is-open");
                toggle.setAttribute("aria-expanded", isOpen.toString());
            });
        })();
    </script>
    @await Html.PartialAsync("_PortalFooter")
