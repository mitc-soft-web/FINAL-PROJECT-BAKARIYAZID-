@using QRCodeAttendance.Models.DTOs.Instructor
@using QRCodeAttendance.Models.Enums
@model UpdateInstructorRequestModel
@{
    ViewData["Title"] = "Edit Instructor Profile";
    Layout = null;
}

<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #10b981;
            --surface: rgba(15, 23, 42, 0.75);
            --border: rgba(255, 255, 255, 0.08);
            --input-bg: rgba(255, 255, 255, 0.03);
            --text-main: #f8fafc;
            --text-dim: #94a3b8;
        }

        body {
            background: radial-gradient(circle at top right, rgba(16, 185, 129, 0.1), transparent),
                        radial-gradient(circle at bottom left, rgba(6, 182, 212, 0.1), transparent),
                        url('https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?q=80&w=2000&auto=format&fit=crop');
            background-size: cover;
            background-attachment: fixed;
            min-height: 100vh;
            color: var(--text-main);
            font-family: 'Plus Jakarta Sans', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            animation: fadeIn 0.8s ease-out;
        }

        .edit-page-shell {
            min-height: calc(100dvh - var(--portal-header-height, 76px) - var(--portal-footer-height, 56px));
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: clamp(1rem, 3vw, 2rem);
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .edit-container {
            width: 100%;
            max-width: 900px;
            margin: 0 auto;
            background: var(--surface);
            backdrop-filter: blur(25px) saturate(180%);
            border: 1px solid var(--border);
            border-radius: 40px;
            padding: 3.5rem;
            box-shadow: 0 40px 100px rgba(0,0,0,0.4);
        }

        .header-section {
            margin-bottom: 3rem;
            text-align: center;
        }

        .header-section h1 {
            font-weight: 800;
            letter-spacing: -1.5px;
            margin-bottom: 0.5rem;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .control-label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--primary);
            margin-bottom: 0.5rem;
            font-weight: 700;
            display: block;
        }

        .input-wrapper {
            position: relative;
            background: var(--input-bg);
            border: 1px solid var(--border);
            border-radius: 16px;
            transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            align-items: center;
        }

        .input-wrapper:focus-within {
            border-color: var(--primary);
            background: rgba(255, 255, 255, 0.06);
            box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1);
            transform: scale(1.01);
        }

        .input-icon {
            padding: 0 1.2rem;
            color: var(--text-dim);
            font-size: 1.1rem;
        }

        .form-control, .form-select {
            background: transparent !important;
            border: none !important;
            color: var(--text-main) !important;
            padding: 12px 12px 12px 0;
            box-shadow: none !important;
            font-weight: 500;
        }

        .form-select option {
            background: #1e293b;
            color: white;
        }

        .btn-stack {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            margin-top: 3rem;
        }

        .btn-save {
            width: 100%;
            background: var(--primary);
            color: #0f172a;
            border: none;
            padding: 16px;
            border-radius: 18px;
            font-weight: 800;
            transition: 0.3s;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .btn-save:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(16, 185, 129, 0.3);
            filter: brightness(1.1);
        }

        .btn-cancel {
            width: 100%;
            background: rgba(255, 255, 255, 0.05);
            color: var(--text-main);
            border: 1px solid var(--border);
            padding: 16px;
            border-radius: 18px;
            font-weight: 600;
            transition: 0.3s;
            text-decoration: none;
            text-align: center;
        }

        .btn-cancel:hover {
            background: rgba(255, 255, 255, 0.1);
            color: white;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .edit-page-shell { align-items: flex-start; }
            .edit-container { padding: 2rem; }
            .row > div { margin-bottom: 1rem; }
        }
    </style>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="with-portal-chrome">
    @await Html.PartialAsync("_PortalHeader")

    <main class="edit-page-shell">
    <div class="edit-container">
        <div class="header-section">
            <div class="d-inline-block p-3 mb-3" style="background: rgba(16, 185, 129, 0.1); border-radius: 20px;">
                <i class="fas fa-user-edit fa-2x text-primary"></i>
            </div>
            <h1>Update Profile</h1>
            <p class="text-dim">Enhance your professional identity in the system</p>
        </div>

        <form asp-controller="Instructor" asp-action="UpdateProfile" method="post">
            <div class="row">
                <div class="col-md-6 form-group">
                    <label class="control-label" asp-for="FirstName">First Name</label>
                    <div class="input-wrapper">
                        <i class="fas fa-id-card input-icon"></i>
                        <input asp-for="FirstName" class="form-control" placeholder="Enter first name" />
                    </div>
                </div>

                <div class="col-md-6 form-group">
                    <label class="control-label" asp-for="LastName">Last Name</label>
                    <div class="input-wrapper">
                        <i class="fas fa-signature input-icon"></i>
                        <input asp-for="LastName" class="form-control" placeholder="Enter last name" />
                    </div>
                </div>

                <div class="col-md-7 form-group">
                    <label class="control-label" asp-for="Email">Email</label>
                    <div class="input-wrapper">
                        <i class="fas fa-envelope input-icon"></i>
                        <input asp-for="Email" class="form-control" type="email" placeholder="email@institution.com" />
                    </div>
                </div>

                <div class="col-md-5 form-group">
                    <label class="control-label" asp-for="PhoneNumber">Phone Number</label>
                    <div class="input-wrapper">
                        <i class="fas fa-phone input-icon"></i>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="+123..." />
                    </div>
                </div>

                <div class="col-md-6 form-group">
                    <label class="control-label" asp-for="Department">Department</label>
                    <div class="input-wrapper">
                        <i class="fas fa-university input-icon"></i>
                        <select asp-for="Department" class="form-select" asp-items="Html.GetEnumSelectList<Departments>()"></select>
                    </div>
                </div>

                <div class="col-md-6 form-group">
                    <label class="control-label" asp-for="Gender">Gender</label>
                    <div class="input-wrapper">
                        <i class="fas fa-venus-mars input-icon"></i>
                        <select asp-for="Gender" class="form-select" asp-items="Html.GetEnumSelectList<Gender>()"></select>
                    </div>
                </div>

                <div class="col-md-6 form-group">
                    <label class="control-label" asp-for="DateOfBirth">Date of Birth</label>
                    <div class="input-wrapper">
                        <i class="fas fa-calendar-alt input-icon"></i>
                        <input asp-for="DateOfBirth" class="form-control" type="date" value="@Model.DateOfBirth.ToString("yyyy-MM-dd")" />
                    </div>
                </div>

                <div class="col-md-12 form-group">
                    <label class="control-label" asp-for="Address">Residential Address</label>
                    <div class="input-wrapper">
                        <i class="fas fa-map-marker-alt input-icon"></i>
                        <input asp-for="Address" class="form-control" placeholder="Street, City, State" />
                    </div>
                </div>
            </div>

            <div class="btn-stack">
                <button type="submit" class="btn-save">
                    <i class="fas fa-check-circle me-2"></i> Save Changes
                </button>
                <a asp-action="InsProfile" class="btn-cancel">Discard</a>
            </div>
        </form>
    </div>
    </main>

    @await Html.PartialAsync("_PortalFooter")
</body>
</html>
