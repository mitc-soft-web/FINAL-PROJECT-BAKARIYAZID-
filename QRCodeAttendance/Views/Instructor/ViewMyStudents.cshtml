@using QRCodeAttendance.Models.DTOs.Student;
@using QRCodeAttendance.Models.DTOs.StudentDto
@using QRCodeAttendance.Models.Entities
@model IReadOnlyList<StudentDto>

@{
    ViewData["Title"] = "My Students";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --glass-bg: rgba(255, 255, 255, 0.07);
        --glass-border: rgba(255, 255, 255, 0.18);
        --glass-highlight: rgba(255, 255, 255, 0.1);
        --accent-color: #4ade80; /* Vibrant Green */
    }

    body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        min-height: 100vh;
        color: white;
    }

    /* Clean Glass Card */
    .pro-glass-card {
        background: var(--glass-bg);
        backdrop-filter: blur(15px) saturate(180%);
        -webkit-backdrop-filter: blur(15px) saturate(180%);
        border: 1px solid var(--glass-border);
        border-radius: 24px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        overflow: hidden;
    }

    /* Professional Table Styling */
    .table-container {
        border-radius: 16px;
        overflow: hidden;
        background: rgba(0, 0, 0, 0.2);
    }

    .clean-table {
        margin-bottom: 0;
        border-collapse: collapse;
    }

    .clean-table thead {
        background: rgba(255, 255, 255, 0.03);
    }

    .clean-table thead th {
        color: rgba(255, 255, 255, 0.5);
        font-weight: 600;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        padding: 20px;
        border: none;
    }

    .clean-table tbody tr {
        border-bottom: 1px solid var(--glass-border);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        animation: fadeInUp 0.5s ease backwards;
    }

    /* Staggered Row Animation */
    @for (int i = 1; i <= 20; i++) {
        <text>
        .clean-table tbody tr:nth-child(@i) { animation-delay: @(i * 0.05)s; }
        </text>
    }

    .clean-table tbody tr:hover {
        background: var(--glass-highlight);
        transform: translateX(8px);
    }

    .clean-table td {
        padding: 18px 20px;
        border: none;
        vertical-align: middle;
        font-size: 0.9rem;
    }

    /* Animated Status Badges */
    .level-badge {
        background: rgba(74, 222, 128, 0.1);
        color: var(--accent-color);
        border: 1px solid rgba(74, 222, 128, 0.2);
        padding: 6px 14px;
        border-radius: 100px;
        font-weight: 600;
        font-size: 0.75rem;
    }

    /* Action Button Glow */
    .btn-action {
        min-height: 38px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 0 16px;
        background: var(--accent-color);
        border: 1px solid rgba(74, 222, 128, 0.55);
        color: #052e16;
        border-radius: 12px;
        transition: all 0.3s;
        text-decoration: none;
        font-weight: 900;
        white-space: nowrap;
        box-shadow: 0 10px 22px rgba(74, 222, 128, 0.25);
    }

    .btn-action:hover {
        background: #86efac;
        color: #052e16;
        box-shadow: 0 0 20px rgba(74, 222, 128, 0.5);
        transform: translateY(-2px);
    }

    /* Back Button */
    .btn-back {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--glass-border);
        color: white;
        padding: 10px 20px;
        border-radius: 14px;
        text-decoration: none;
        font-weight: 500;
        transition: all 0.3s;
    }

    .btn-back:hover {
        background: white;
        color: #0f172a;
    }

    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@media (max-width: 768px) {
        .container {
            width: min(100% - 18px, 420px);
            padding-left: 0;
            padding-right: 0;
        }

        .pro-glass-card {
            padding: 1rem !important;
        }

        .row.align-items-center.mb-5 {
            margin-bottom: 1.5rem !important;
        }

        .row.align-items-center.mb-5 > div {
            width: 100%;
        }

        .d-flex.align-items-center.mb-2 {
            align-items: flex-start !important;
        }

        h2.h3 {
            font-size: 1.25rem;
            line-height: 1.25;
            overflow-wrap: anywhere;
        }

        p.text-white-50.mb-0.ms-4 {
            margin-left: 0 !important;
            line-height: 1.6;
        }

        .table-container,
        .table-responsive {
            overflow: visible;
            background: transparent;
        }

        body.with-portal-chrome .clean-table,
        .clean-table {
            min-width: 0 !important;
            width: 100% !important;
        }

        .clean-table thead {
            display: none;
        }

        .clean-table,
        .clean-table tbody,
        .clean-table tr,
        .clean-table td {
            display: block;
            width: 100%;
        }

        .clean-table tbody tr {
            margin-bottom: 1rem;
            border: 1px solid var(--glass-border);
            border-radius: 18px;
            background: rgba(255, 255, 255, 0.06);
            overflow: hidden;
            box-shadow: 0 18px 35px rgba(0, 0, 0, 0.22);
        }

        .clean-table tbody tr:hover {
            transform: none;
        }

        .clean-table td {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 1rem;
            padding: 0.85rem 1rem;
            text-align: right;
            overflow-wrap: anywhere;
        }

        .clean-table td::before {
            content: attr(data-label);
            color: rgba(255, 255, 255, 0.58);
            font-size: 0.72rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            text-align: left;
        }

        .clean-table td:first-child {
            display: block;
            text-align: left;
        }

        .clean-table td:first-child::before {
            display: block;
            margin-bottom: 0.65rem;
        }

        .clean-table td:last-child {
            text-align: left;
        }

        .clean-table td:last-child .d-flex,
        .btn-action {
            width: 100%;
            justify-content: center;
        }

        .clean-table td[data-label="Level"] {
            align-items: center;
        }

        .level-badge {
            max-width: 100%;
            text-align: right;
            white-space: normal;
        }

        .btn-back {
            display: inline-flex;
            width: 100%;
            justify-content: center;
        }

        .d-flex.justify-content-between.align-items-center.mt-4 {
            align-items: flex-start !important;
            flex-direction: column;
            gap: 0.5rem;
        }
    }

    @@media (max-width: 420px) {
        .clean-table td {
            display: block;
            text-align: left;
        }

        .clean-table td::before {
            display: block;
            margin-bottom: 0.35rem;
        }

        .clean-table td[data-label="Student"] .d-flex {
            align-items: flex-start !important;
        }
    }
</style>

<div class="container py-5">
    <div class="pro-glass-card p-4 animate__animated animate__fadeIn">
        
        <div class="row align-items-center mb-5">
            <div class="col-md-8">
                <div class="d-flex align-items-center mb-2">
                    <div style="width: 3px; height: 30px; background: var(--accent-color); margin-right: 15px; border-radius: 10px;"></div>
                    <h2 class="h3 fw-bold mb-0">@ViewBag.Level Student Roster</h2>
                </div>
                <p class="text-white-50 mb-0 ms-4">
                    Instructor: <span class="text-white">@(User.Identity?.Name ?? "Instructor")</span> | 
                    Department: <span class="badge" style="background: rgba(255,255,255,0.1)">@ViewBag.Department</span>
                </p>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                <a asp-action="InstructorDashboard" class="btn-back">
                    <i class="fas fa-grid-2 me-2"></i> Dashboard
                </a>
            </div>
        </div>

        <div class="table-container">
            <div class="table-responsive">
                <table class="table clean-table">
                    <thead>
                        <tr>
                            <th class="text-black-50">Student Name</th>
                            <th class="text-black-50">Matric Number</th>
                            <th class="text-black-50">Gender</th>
                            <th class="text-black-50">Level</th>
                            @* <th class="text-center text-black-50">Report</th> *@
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var student in Model)
                            {
                                <tr>
                                    <td data-label="Student">
                                        <div class="d-flex align-items-center">
                                            <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center me-3" style="width: 35px; height: 35px; background: linear-gradient(45deg, #4ade80, #3b82f6) !important; font-size: 0.8rem; font-weight: bold;">
                                                @student.FullName.Substring(0, 1)
                                            </div>
                                            <span class="fw-semibold">@student.FullName</span>
                                        </div>
                                    </td>
                                    <td class="fw-semibold" data-label="Matric">@student.MatricNumber<span class="form-control-plaintext"></span></td>
                                    <td class="fw-semibold" data-label="Gender">@student.Gender</td>
                                    <td data-label="Level">
                                        <span class="level-badge fw-semibold">@student.StudentLevel.GetDescription()</span>
                                    </td>
                                    @* <td class="text-center" data-label="Report">
                                        <div class="d-flex justify-content-center">
                                            <a asp-controller="Student" asp-action="AttendanceReport" asp-route-id="@student.StudentId" 
                                               class="btn-action" title="View Full Report">
                                                <i class="fas fa-arrow-right"></i>
                                                <span>View Report</span>
                                            </a>
                                        </div>
                                    </td>*@
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5">
                                    <div class="opacity-25 mb-3">
                                        <i class="fas fa-folder-open fa-3x"></i>
                                    </div>
                                    <h5 class="text-white-50">No students registered yet</h5>
                                    <p class="small text-muted">Students in the @ViewBag.Level level will appear here.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-4 px-2">
            <div class="text-white-50 small">
                Showing <strong>@Model?.Count()</strong> results
            </div>
            <div class="text-white-50 small">
                <i class="fas fa-clock me-1"></i> Last updated: @DateTime.UtcNow.ToLocalTime().ToString("MMM dd, yyyy - hh:mm tt")
            </div>
        </div>
    </div>
</div>
