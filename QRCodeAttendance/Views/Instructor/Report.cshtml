@using System.Text.Json
@using QRCodeAttendance.Models.Enums
@model QRCodeAttendance.Models.DTOs.Reports.CourseReportDto

@{
    ViewData["Title"] = "Attendance Analytics Report";

    var records = Model?.AttendanceRecords ?? new();
    var courseCode = string.IsNullOrWhiteSpace(Model?.CourseCode) ? "Course" : Model.CourseCode;
    var courseName = string.IsNullOrWhiteSpace(Model?.CourseName) ? "Attendance Report" : Model.CourseName;
    var instructorName = string.IsNullOrWhiteSpace(Model?.InstructorName) ? "Instructor" : Model.InstructorName;
    var attendanceRate = Math.Round(Model?.AverageAttendancePercentage ?? 0, 1);
    var generatedDate = DateTime.Now;
    var totalMarked = (Model?.TotalPresent ?? 0) + (Model?.TotalLate ?? 0) + (Model?.TotalAbsent ?? 0);
    var exportFileName = $"{courseCode}-attendance-report.csv";
    var reportRows = records.Select(record => new
    {
        studentName = record.StudentName,
        studentEmail = record.StudentEmail,
        sessionDate = record.SessionDate.ToString("yyyy-MM-dd"),
        scanTime = record.ScanTime?.ToString("hh:mm tt") ?? "",
        status = record.Status ?? "Unknown"
    });
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

    :root {
        --report-bg: #f6f8fb;
        --report-surface: #ffffff;
        --report-border: #dfe7ef;
        --report-text: #102033;
        --report-muted: #5f7184;
        --report-soft: #f1f5f9;
        --report-primary: #0f766e;
        --report-primary-dark: #115e59;
        --report-blue: #1d4ed8;
        --report-success: #047857;
        --report-success-bg: #ecfdf5;
        --report-warning: #b45309;
        --report-warning-bg: #fffbeb;
        --report-danger: #b91c1c;
        --report-danger-bg: #fef2f2;
        --report-shadow: 0 16px 36px rgba(15, 23, 42, 0.07);
    }

    body {
        background: var(--report-bg);
        color: var(--report-text);
        font-family: 'Plus Jakarta Sans', sans-serif;
        -webkit-font-smoothing: antialiased;
    }

    .report-page {
        padding: 2rem 0 3rem;
    }

    .report-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .report-actions {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .report-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        min-height: 42px;
        padding: 0 1rem;
        border-radius: 8px;
        border: 1px solid transparent;
        font-size: 0.9rem;
        font-weight: 700;
        text-decoration: none;
        transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
    }

    .report-btn:hover {
        transform: translateY(-1px);
    }

    .report-btn-primary {
        background: var(--report-primary);
        color: #ffffff;
        box-shadow: 0 10px 20px rgba(15, 118, 110, 0.18);
    }

    .report-btn-primary:hover {
        background: var(--report-primary-dark);
        color: #ffffff;
    }

    .report-btn-secondary {
        background: #ffffff;
        border-color: var(--report-border);
        color: var(--report-text);
    }

    .report-btn-secondary:hover {
        background: var(--report-soft);
        color: var(--report-text);
    }

    .report-cover {
        background: var(--report-surface);
        border: 1px solid var(--report-border);
        border-radius: 14px;
        box-shadow: var(--report-shadow);
        overflow: hidden;
        margin-bottom: 1rem;
    }

    .report-cover-top {
        height: 6px;
        background: var(--report-primary);
    }

    .report-cover-body {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 1.5rem;
        align-items: center;
        padding: 1.5rem;
    }

    .report-brand {
        display: flex;
        align-items: center;
        gap: 1rem;
        min-width: 0;
    }

    .report-brand-mark {
        width: 62px;
        height: 62px;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid var(--report-border);
        background: #ffffff;
        display: flex;
        align-items: center;
        justify-content: center;
        flex: 0 0 auto;
    }

    .report-brand-mark img {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    .report-kicker {
        color: var(--report-primary);
        font-size: 0.74rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 0.35rem;
    }

    .report-title {
        margin: 0;
        color: var(--report-text);
        font-size: clamp(1.2rem, 2vw, 1rem);
        font-weight: 750;
        line-height: 1.1;
    }

    .report-subtitle {
        margin: 0.45rem 0 0;
        color: var(--report-muted);
        font-size: 0.95rem;
        line-height: 1.5;
    }

    .report-score {
        min-width: 184px;
        padding: 1rem;
        border-radius: 12px;
        background: #f0fdfa;
        border: 1px solid #c6f3ee;
        text-align: center;
    }

    .report-score-value {
        color: var(--report-primary-dark);
        font-size: 2.15rem;
        font-weight: 800;
        line-height: 1;
    }

    .report-score-label {
        color: var(--report-muted);
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-top: 0.45rem;
    }

    .report-meta {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1px;
        background: var(--report-border);
        border-top: 1px solid var(--report-border);
    }

    .report-meta-item {
        background: #fbfcfd;
        padding: 1rem 1.25rem;
        min-width: 0;
    }

    .report-label {
        color: var(--report-muted);
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 0.35rem;
    }

    .report-value {
        color: var(--report-text);
        font-weight: 700;
        overflow-wrap: anywhere;
    }

    .metric-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .metric-card {
        background: var(--report-surface);
        border: 1px solid var(--report-border);
        border-radius: 12px;
        padding: 1.15rem;
        min-height: 120px;
        box-shadow: 0 8px 20px rgba(15, 23, 42, 0.04);
    }

    .metric-card-header {
        display: flex;
        justify-content: space-between;
        gap: 0.75rem;
        align-items: center;
        margin-bottom: 1rem;
    }

    .metric-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: var(--report-soft);
        color: var(--report-blue);
    }

    .metric-value {
        font-size: 1.8rem;
        font-weight: 800;
        line-height: 1;
        color: var(--report-text);
    }

    .metric-note {
        margin-top: 0.5rem;
        color: var(--report-muted);
        font-size: 0.82rem;
    }

    .report-panel {
        background: var(--report-surface);
        border: 1px solid var(--report-border);
        border-radius: 14px;
        box-shadow: var(--report-shadow);
        overflow: hidden;
    }

    .report-panel-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--report-border);
        background: #fbfcfd;
    }

    .report-panel-title {
        margin: 0;
        font-size: 1.05rem;
        font-weight: 800;
        color: var(--report-text);
    }

    .report-panel-caption {
        margin: 0.35rem 0 0;
        color: var(--report-muted);
        font-size: 0.9rem;
    }

    .record-count {
        flex: 0 0 auto;
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        border-radius: 999px;
        background: var(--report-soft);
        color: var(--report-muted);
        padding: 0.45rem 0.75rem;
        font-size: 0.8rem;
        font-weight: 700;
    }

    .report-table {
        margin: 0;
        min-width: 760px;
    }

    .report-table thead th {
        background: #f8fafc;
        border-bottom: 1px solid var(--report-border);
        color: var(--report-muted);
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        padding: 0.9rem 1.25rem;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .report-table tbody td {
        border-bottom: 1px solid #edf2f7;
        color: var(--report-text);
        padding: 1rem 1.25rem;
        vertical-align: middle;
    }

    .report-table tbody tr:last-child td {
        border-bottom: 0;
    }

    .report-table tbody tr:hover {
        background: #fbfcfd;
    }

    .student-name {
        font-weight: 800;
        color: var(--report-text);
    }

    .student-email,
    .muted-cell {
        color: var(--report-muted);
        font-size: 0.88rem;
    }

    .status-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        min-width: 86px;
        justify-content: center;
        padding: 0.42rem 0.7rem;
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 800;
    }

    .status-present {
        background: var(--report-success-bg);
        color: var(--report-success);
    }

    .status-late {
        background: var(--report-warning-bg);
        color: var(--report-warning);
    }

    .status-absent {
        background: var(--report-danger-bg);
        color: var(--report-danger);
    }

    .status-unknown {
        background: var(--report-soft);
        color: var(--report-muted);
    }

    .weight-track {
        width: 88px;
        height: 8px;
        border-radius: 999px;
        background: #e5eaf0;
        overflow: hidden;
    }

    .weight-fill {
        height: 100%;
        border-radius: inherit;
        background: var(--report-primary);
    }

    .empty-state {
        padding: 3rem 1.5rem;
        text-align: center;
        color: var(--report-muted);
    }

    .empty-state i {
        display: block;
        color: #94a3b8;
        font-size: 2rem;
        margin-bottom: 0.75rem;
    }

    @@media (max-width: 992px) {
        .report-cover-body,
        .report-meta,
        .metric-grid {
            grid-template-columns: 1fr 1fr;
        }

        .report-score {
            min-width: 0;
        }
    }

    @@media (max-width: 768px) {
        .report-page {
            padding: 1rem 0 2rem;
        }

        .report-toolbar,
        .report-panel-header {
            flex-direction: column;
            align-items: stretch;
        }

        .report-actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
        }

        .report-btn {
            width: 100%;
        }

        .report-cover-body,
        .report-meta,
        .metric-grid {
            grid-template-columns: 1fr;
        }

        .report-cover-body,
        .report-panel-header {
            padding: 1.1rem;
        }

        .metric-card {
            min-height: 0;
        }
    }

    @@media print {
        .no-print,
        .app-shell-header,
        .app-shell-footer {
            display: none !important;
        }

        body {
            background: #ffffff !important;
            color: #000000 !important;
        }

        .container {
            max-width: 100% !important;
        }

        .report-page {
            padding: 0;
        }

        .report-cover,
        .metric-card,
        .report-panel {
            box-shadow: none !important;
            border-color: #cbd5e1 !important;
            break-inside: avoid;
        }

        .report-cover-top {
            background: #000000 !important;
        }

        .report-table {
            min-width: 0;
            font-size: 0.82rem;
        }

        .report-table thead th,
        .report-table tbody td {
            padding: 0.6rem;
        }
    }
</style>

<div class="container report-page">
    <div class="report-toolbar no-print">
        <a asp-action="InstructorDashboard" asp-controller="Instructor" class="report-btn report-btn-secondary">
            <i class="fas fa-arrow-left"></i>
            Dashboard
        </a>

        <div class="report-actions">
            <button type="button" class="report-btn report-btn-secondary" onclick="window.print()">
                <i class="fas fa-print"></i>
                Print
            </button>
            <button type="button" class="report-btn report-btn-primary" id="exportReportCsv">
                <i class="fas fa-download"></i>
                Export CSV
            </button>
        </div>
    </div>

    <section class="report-cover" aria-label="Report summary">
        <div class="report-cover-top"></div>
        <div class="report-cover-body">
            <div class="report-brand">
                <div class="report-brand-mark">
                    <img src="~/images/mitc-logo.jpg" asp-append-version="true" alt="MITC logo" />
                </div>
                <div>
                    <div class="report-kicker">Official Attendance Report</div>
                    <h1 class="report-title">@courseCode: @courseName</h1>
                    <p class="report-subtitle">Masroor International Technical College QR Code Attendance</p>
                </div>
            </div>

            <div class="report-score">
                <div class="report-score-value">@attendanceRate%</div>
                <div class="report-score-label">Average Rate</div>
            </div>
        </div>

        <div class="report-meta">
            <div class="report-meta-item">
                <div class="report-label">Instructor</div>
                <div class="report-value">@instructorName</div>
            </div>
            <div class="report-meta-item">
                <div class="report-label">Generated</div>
                <div class="report-value">@generatedDate.ToString("MMM dd, yyyy h:mm tt")</div>
            </div>
            <div class="report-meta-item">
                <div class="report-label">Records</div>
                <div class="report-value">@records.Count attendance entries</div>
            </div>
        </div>
    </section>

    <section class="metric-grid" aria-label="Attendance metrics">
        <article class="metric-card">
            <div class="metric-card-header">
                <div>
                    <div class="report-label">Sessions</div>
                    <div class="metric-value">@(Model?.TotalSessions ?? 0)</div>
                </div>
                <div class="metric-icon"><i class="fas fa-calendar-check"></i></div>
            </div>
            <div class="metric-note">Completed class sessions included in this report.</div>
        </article>

        <article class="metric-card">
            <div class="metric-card-header">
                <div>
                    <div class="report-label">Present</div>
                    <div class="metric-value" style="color: var(--report-success);">@(Model?.TotalPresent ?? 0)</div>
                </div>
                <div class="metric-icon" style="background: var(--report-success-bg); color: var(--report-success);"><i class="fas fa-check"></i></div>
            </div>
            <div class="metric-note">@((totalMarked == 0 ? 0 : Math.Round(((Model?.TotalPresent ?? 0) * 100.0) / totalMarked, 1)))% of marked attendance.</div>
        </article>

        <article class="metric-card">
            <div class="metric-card-header">
                <div>
                    <div class="report-label">Late</div>
                    <div class="metric-value" style="color: var(--report-warning);">@(Model?.TotalLate ?? 0)</div>
                </div>
                <div class="metric-icon" style="background: var(--report-warning-bg); color: var(--report-warning);"><i class="fas fa-clock"></i></div>
            </div>
            <div class="metric-note">Students who completed attendance after the first scan window.</div>
        </article>

        <article class="metric-card">
            <div class="metric-card-header">
                <div>
                    <div class="report-label">Absent</div>
                    <div class="metric-value" style="color: var(--report-danger);">@(Model?.TotalAbsent ?? 0)</div>
                </div>
                <div class="metric-icon" style="background: var(--report-danger-bg); color: var(--report-danger);"><i class="fas fa-xmark"></i></div>
            </div>
            <div class="metric-note">Students without a completed valid scan.</div>
        </article>
    </section>

    <section class="report-panel" aria-label="Detailed attendance log">
        <div class="report-panel-header">
            <div>
                <h2 class="report-panel-title">Detailed Attendance Log</h2>
                <p class="report-panel-caption">Student-level record of session date, scan time, status, and attendance weight.</p>
            </div>
            <span class="record-count">
                <i class="fas fa-list-check"></i>
                @records.Count records
            </span>
        </div>

        @if (records.Any())
        {
            <div class="table-responsive">
                <table class="table report-table align-middle">
                    <thead>
                        <tr>
                            <th>Student</th>
                            <th>Session Date</th>
                            <th>Scan Time</th>
                            <th>Status</th>
                            <th>Weight</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var record in records)
                        {
                            var recordStatus = record.Status ?? "Unknown";
                            var normalizedStatus = recordStatus.Trim().ToLowerInvariant();
                            var statusClass = normalizedStatus switch
                            {
                                "present" => "status-present",
                                "late" => "status-late",
                                "absent" => "status-absent",
                                _ => "status-unknown"
                            };
                            var weight = normalizedStatus == "present" ? 100 : normalizedStatus == "late" ? 50 : 0;

                            <tr>
                                <td>
                                    <div class="student-name">@record.StudentName</div>
                                    <div class="student-email">@record.StudentEmail</div>
                                </td>
                                <td class="fw-bold">@record.SessionDate.ToString("dd MMM yyyy")</td>
                                <td class="muted-cell">@(record.ScanTime?.ToString("hh:mm tt") ?? "Not scanned")</td>
                                <td>
                                    <span class="status-pill @statusClass">
                                        @if (normalizedStatus == "present")
                                        {
                                            <i class="fas fa-check"></i>
                                        }
                                        else if (normalizedStatus == "late")
                                        {
                                            <i class="fas fa-clock"></i>
                                        }
                                        else if (normalizedStatus == "absent")
                                        {
                                            <i class="fas fa-xmark"></i>
                                        }
                                        else
                                        {
                                            <i class="fas fa-minus"></i>
                                        }
                                        @recordStatus
                                    </span>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="weight-track" aria-hidden="true">
                                            <div class="weight-fill" style="width: @weight%;"></div>
                                        </div>
                                        <span class="muted-cell">@weight%</span>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-clipboard-list"></i>
                <strong>No attendance records available yet.</strong>
                <div>Records will appear here once students scan an active session QR code.</div>
            </div>
        }
    </section>
</div>

<script>
    (() => {
        const exportButton = document.getElementById("exportReportCsv");
        const rows = @Html.Raw(JsonSerializer.Serialize(reportRows));
        const fileName = @Html.Raw(JsonSerializer.Serialize(exportFileName));

        if (!exportButton) {
            return;
        }

        const escapeCsv = (value) => {
            const text = `${value ?? ""}`;
            return `"${text.replace(/"/g, '""')}"`;
        };

        exportButton.addEventListener("click", () => {
            const header = ["Student Name", "Student Email", "Session Date", "Scan Time", "Status"];
            const csvRows = [
                header.map(escapeCsv).join(","),
                ...rows.map((row) => [
                    row.studentName,
                    row.studentEmail,
                    row.sessionDate,
                    row.scanTime,
                    row.status
                ].map(escapeCsv).join(","))
            ];

            const blob = new Blob([csvRows.join("\r\n")], { type: "text/csv;charset=utf-8;" });
            const url = URL.createObjectURL(blob);
            const link = document.createElement("a");
            link.href = url;
            link.download = fileName;
            document.body.appendChild(link);
            link.click();
            link.remove();
            URL.revokeObjectURL(url);
        });
    })();
</script>
